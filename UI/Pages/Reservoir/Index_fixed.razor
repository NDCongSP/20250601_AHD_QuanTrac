@* @page "/reservoir"
@using System.Text.RegularExpressions
@using System.Timers
@using System.ComponentModel
@using UI.StaticClass
@using Application.Services
@using Microsoft.Extensions.Localization
@using Microsoft.JSInterop
@using Blazored.LocalStorage
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Authorization
@using Radzen.Blazor
@using Domain.Models
@inject IJSRuntime JSRuntime
@attribute [Authorize(Policy = "Admin")]

<style>
    .rz-legend-item {
        text-wrap: nowrap !important;
    }

    .rz-series-data-label-fill {
        font-size: small;
    }
</style>

<div class="main-container">
    <!-- Top Section with 3 columns -->
    <div class="top-section">
        <RadzenRow class="h-100">
            <!-- First Column with Fieldset -->
            <RadzenColumn SizeXS="12" SizeLG="4" class="rz-mx-auto equal-height-column">
                <div class="column-container">
                    <div class="column-header">
                        @_localizer["Hồ chứa"]
                    </div>
                    <div class="column-content">
                        <RadzenRow>
                            <RadzenColumn SizeXS="12" SizeMD="12" class="svg-container">
                                @((MarkupString)_svg)
                            </RadzenColumn>
                        </RadzenRow>
                    </div>
                </div>
            </RadzenColumn>

            <!-- Second Column without Fieldset -->
            <RadzenColumn SizeXS="12" SizeLG="3" class="rz-mx-auto equal-height-column" Style="height: 365px;">
                <RadzenDataGrid Data="@apiData" Style="height: 100%;"
                                TItem="KeyValuePair<string, double>" AllowFiltering="false" AllowColumnResize="true" AllowSorting="false"
                                AllowPaging="false" ShowPagingSummary="false">
                    <Columns>
                        <RadzenDataGridColumn TItem="KeyValuePair<string, double>" Title="Vị trí" Property="Key" />
                        <RadzenDataGridColumn TItem="KeyValuePair<string, double>" Title="Giá trị (m)" Property="Value"
                                              FormatString="{0:N2}" TextAlign="TextAlign.Right" />
                    </Columns>
                    <EmptyTemplate>
                        <div class="rz-datatable-emptymessage" style="text-align: center; padding: 10px;">
                            @_localizer["Không có dữ liệu"]
                        </div>
                    </EmptyTemplate>
                </RadzenDataGrid>
            </RadzenColumn>

            <!-- Third Column without Fieldset -->
            <RadzenColumn SizeXS="12" SizeLG="5" class="rz-mx-auto equal-height-column">
                <div class="map-container" style="border-top: none;height: 365px;">
                    <iframe src="https://vrain.vn/61/overview?public_map=windy"
                            style="width: 100%; height: 100%; border: none; border-radius: 0 0 4px 4px;" allowfullscreen>
                    </iframe>
                </div>
            </RadzenColumn>
        </RadzenRow>
    </div>

    <!-- Bottom Section with Stacked Area Chart -->
    <div class="bottom-section">
        <div class="chart-wrapper">
            <div class="chart-header" style="font-weight: bold;">
                Zmndbt (m): 24.40 &nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Wmndbt (10<sup>6</sup>m<sup>3</sup>): 1580.80
            </div>
            <div class="chart-container">
                <RadzenChart @ref="_chart" Style="width: 100%; height: 100%;">
                    <!-- Line Series (L_*) -->
                    @{
                        var lineProps = typeof(FT05_ChartHoChuaModel).GetProperties()
                        .Where(p => p.Name.StartsWith("L_") && p.PropertyType == typeof(double?))
                        .ToList();

                        foreach (var prop in lineProps)
                        {
                            var displayName = (prop.GetCustomAttributes(typeof(DisplayNameAttribute), false)
                            .FirstOrDefault() as DisplayNameAttribute)?.DisplayName ?? prop.Name.Replace("L_", "");
                            var strokeColor = displayName switch
                            {
                                string s when s.Contains("CTDD") => "#A31629",
                                string s when s.Contains("DPL") => "#B5131E",
                                string s when s.Contains("HCCN") => "#B5131E",
                                string s when s.Contains("DPPH") => "#CB46C2",
                                string s when s.Contains("Fllow_TL_CDD") => "blue",
                                _ => "black"
                            };

                            <RadzenLineSeries Data="@chartData" CategoryProperty="X_Value"
                                              Stroke="black" Title="@displayName" ValueProperty="@prop.Name"
                                              LineType="LineType.Solid">
                                <RadzenSeriesDataLabels Visible="false" />
                                <RadzenMarkers Visible="true" Size="3" Fill="@strokeColor" MarkerType="MarkerType.Circle" />
                            </RadzenLineSeries>
                        }

                        <!-- FT03 Data Series -->
                        @if (_ft03ChartData?.Any() == true)
                        {
                            <RadzenLineSeries Data="@_ft03ChartData"
                                              CategoryProperty="X_Value"
                                              Stroke="blue"
                                              Title="Fllow_TL_CDD"
                                              ValueProperty="Value"
                                              LineType="LineType.Solid">
                                <RadzenSeriesDataLabels Visible="false" />
                                <RadzenMarkers Visible="true" Size="3" Fill="blue" MarkerType="MarkerType.Circle" />
                            </RadzenLineSeries>
                        }
                    }

                    <!-- Area Series (A_*) -->
                    @{
                        var areaProps = typeof(FT05_ChartHoChuaModel).GetProperties()
                        .Where(p => p.Name.StartsWith("A_") && p.PropertyType == typeof(double?))
                        .OrderByDescending(x => x.Name)
                        .ToList();

                        foreach (var prop in areaProps)
                        {
                            var displayName = (prop.GetCustomAttributes(typeof(DisplayNameAttribute), false)
                            .FirstOrDefault() as DisplayNameAttribute)?.DisplayName ?? prop.Name.Replace("A_", "");

                            var fillColor = displayName.Contains("A") ? "#C49078" : displayName.Contains("B") ? "#A9D1AE" : "#E0EFF6";
                            var strokeColor = displayName.Contains("A") ? "#E51300" : displayName.Contains("B") ? "#DD10D9" : "#AB3130";
                            var isVisible = displayName.Contains("C") || displayName.Contains("B");
                            <RadzenAreaSeries Data="@chartData" CategoryProperty="X_Value"
                                              Title="@displayName"
                                              Fill="@fillColor"
                                              Stroke="@strokeColor"
                                              ValueProperty="@prop.Name">
                                <RadzenSeriesDataLabels Visible="@isVisible" Fill="@strokeColor" />
                                <RadzenMarkers Visible="true" Size="3" Fill="@strokeColor" MarkerType="MarkerType.Circle" />
                            </RadzenAreaSeries>
                        }
                    }

                    <RadzenLegend Position="LegendPosition.Bottom" />
                    <RadzenCategoryAxis Padding="20" LabelAutoRotation="-45" />
                    <RadzenValueAxis>
                        <RadzenGridLines Visible="true" />
                    </RadzenValueAxis>
                </RadzenChart>
            </div>
        </div>
    </div>
</div>

@code {
    private RadzenChart? _chart;
    private string _svg = string.Empty;
    private System.Timers.Timer _timer = new();
    private List<FT05_ChartHoChuaModel> chartData = new();
    private List<KeyValuePair<string, double>> apiData = new();
    private List<FT03DataPoint> _ft03ChartData = new();
    private RealtimeDisplayModel realtimeData = new();

    private class FT03DataPoint
    {
        public DateTime Date { get; set; }
        public string X_Value { get; set; } = string.Empty;
        public double? Value { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            LayoutState.SetTitle(_localizer["Hồ chứa"]);
            await base.OnInitializedAsync();

            // Load SVG
            using var stream = this.GetType().Assembly.GetManifestResourceStream("UI.wwwroot.images.generals.hochua.svg");
            if (stream != null)
            {
                stream.Seek(0, SeekOrigin.Begin);
                using var reader = new StreamReader(stream);
                _svg = await reader.ReadToEndAsync();
            }

            // Refresh data
            RefreshDataAsync(null, null);

            // Set up timer
            _timer = new System.Timers.Timer(GlobalVariable.ConfigSystem.TimerInterval);
            _timer.Elapsed += RefreshDataAsync;
            _timer.Enabled = true;

            // Load chart data
            await LoadChartData();

            // Load FT03 data
            await LoadFT03Data();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error in OnInitializedAsync: {ex.Message}");
        }
    }

    private async void RefreshDataAsync(object? sender, ElapsedEventArgs? e)
    {
        try
        {
            realtimeData = await _ft02Service.GetFirstOrDefaultRealTimeDisplay();
            GetAPIData();
            await _jsRuntime.InvokeVoidAsync("updateSvgFillOverflow", realtimeData);
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error in RefreshData: {ex.Message}");
        }
    }

    private void GetAPIData()
    {
        apiData = realtimeData.CalculatorValue?.GetType().GetProperties()
            .Where(p => p.Name.StartsWith("API_D_"))
            .Select(p => new KeyValuePair<string, double>(
                _localizer[p.Name.Replace("API_D_", "").Replace("_", " ")] ?? p.Name.Replace("API_D_", ""),
                Convert.ToDouble(p.GetValue(realtimeData.CalculatorValue) ?? 0)
            )).ToList();
    }
    private async Task LoadFT03Data()
    {
        try
        {
            var result = await _ft03Service.GetByFromDateToDateAsync();
            if (result?.Succeeded == true && result.Data != null && result.Data.Any())
            {
                _ft03ChartData = result.Data
                    .Where(x => x != null && x.Date != default && x.Value.HasValue)
                    .Select(x => new FT03DataPoint
                    {
                        Date = x.Date,
                        X_Value = x.Date.ToString("dd-MM"),
                        Value = x.Value
                    })
                    .OrderBy(x => x.Date)  // Ensure data is ordered by date
                    .ToList();

                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading FT03 data: {ex.Message}");
            Console.WriteLine(ex.StackTrace);
        }
    }
    private async Task LoadChartData()
    {
        try
        {
            var result = await _ft05Service.GetAllAsync();
            if (result.Succeeded)
            {
                chartData = result.Data.Select(x => new FT05_ChartHoChuaModel
                {
                    Id = x.Id,
                    Index = x.Index,
                    X_Value = x.X_Value,
                    L_CTDD = x.L_CTDD,
                    L_DPL = x.L_DPL,
                    L_HCCN = x.L_HCCN,
                    L_MNC = x.L_MNC,
                    L_MNDBT = x.L_MNDBT,
                    L_DPPH = x.L_DPPH,
                    A_VungA = x.A_VungA,
                    A_VungB = x.A_VungB,
                    A_VungC = x.A_VungC,
                    
                }).OrderBy(x => x.Index).ToList();
                
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading chart data: {ex.Message}");
        }
    }

    public void Dispose()
    {
        _timer.Elapsed -= RefreshDataAsync;
        _timer.Dispose();
    }
}
 *@