@page "/reservoir"
@using System.Text.RegularExpressions
@using System.Timers
@using System.ComponentModel
@using System.Globalization
@using UI.StaticClass
@using Application.Services
@using Microsoft.Extensions.Localization
@using Microsoft.JSInterop
@using Blazored.LocalStorage
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Authorization
@using Radzen.Blazor
@using Domain.Models
@inject IJSRuntime JSRuntime
@attribute [Authorize(Policy = "Admin")]

<style>
    .rz-legend-item {
        text-wrap: nowrap !important;
    }

    .rz-series-data-label-fill {
        font-size: small;
    }

    .rz-chart-series-marker[data-value='0'] {
        display: none;
    }
</style>

<div class="main-container">
    <!-- Top Section with 3 columns -->
    <div class="top-section">
        <RadzenRow class="h-100">
            <!-- First Column with Fieldset -->
            <RadzenColumn SizeXS="12" SizeLG="4" class="rz-mx-auto equal-height-column">
                <div class="column-container">
                    <div class="column-header">
                        @_localizer["Hồ chứa"]
                    </div>
                    <div class="column-content">
                        <RadzenRow>
                            <RadzenColumn SizeXS="12" SizeMD="12" class="svg-container">
                                @((MarkupString)_svg)
                            </RadzenColumn>
                        </RadzenRow>
                    </div>
                </div>
            </RadzenColumn>

            <!-- Second Column without Fieldset -->
            <RadzenColumn SizeXS="12" SizeLG="3" class="rz-mx-auto equal-height-column" Style="height: 365px;">
                <RadzenDataGrid Data="@apiData" Style="height: 100%;"
                                TItem="KeyValuePair<string, double>" AllowFiltering="false" AllowColumnResize="true" AllowSorting="false"
                                AllowPaging="false" ShowPagingSummary="false">
                    <Columns>
                        <RadzenDataGridColumn TItem="KeyValuePair<string, double>" Title="Vị trí" Property="Key" />
                        <RadzenDataGridColumn TItem="KeyValuePair<string, double>" Title="Giá trị (m)" Property="Value"
                                              FormatString="{0:N2}" TextAlign="TextAlign.Right" />
                    </Columns>
                    <EmptyTemplate>
                        <div class="rz-datatable-emptymessage" style="text-align: center; padding: 10px;">
                            @_localizer["Không có dữ liệu"]
                        </div>
                    </EmptyTemplate>
                </RadzenDataGrid>
            </RadzenColumn>

            <!-- Third Column without Fieldset -->
            <RadzenColumn SizeXS="12" SizeLG="5" class="rz-mx-auto equal-height-column">
                <div class="map-container" style="border-top: none;height: 365px;">
                    <iframe src="https://vrain.vn/61/overview?public_map=windy"
                            style="width: 100%; height: 100%; border: none; border-radius: 0 0 4px 4px;" allowfullscreen>
                    </iframe>
                </div>
            </RadzenColumn>
        </RadzenRow>
    </div>

    <!-- Bottom Section with Stacked Area Chart -->
    <div class="bottom-section">
        <div class="chart-wrapper">
            <div class="chart-header" style="font-weight: bold;">
                Zmndbt (m): 24.40 &nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Wmndbt (10<sup>6</sup>m<sup>3</sup>): 1580.80
            </div>
            <div id="chartContainer">
                <div id="infoLine1" class="chart-label">
                    @_infoLine1
                </div>
                <div id="infoLine2" class="chart-label">
                    @_infoLine2
                </div>
                <canvas id="reservoirChart" height="400"></canvas>
            </div>
        </div>
    </div>
</div>

@code {
    private RadzenChart? _chart;
    private string _svg, _infoLine1, _infoLine2;
    private System.Timers.Timer _timer = new();
    private List<FT05_ChartHoChuaModel> chartData = new();
    private List<KeyValuePair<string, double>> apiData = new();
    private List<FT03DataPoint> _ft03ChartData = new();
    private RealtimeDisplayModel realtimeData = new();
    private DotNetObjectReference<Index> _dotNetHelper;
    private bool _isInitialized = false;
    private List<FT06_InterpolationTable> _ft06Data = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            LayoutState.SetTitle(_localizer["Hồ chứa"]);
            await base.OnInitializedAsync();

            // Load SVG
            using var stream = this.GetType().Assembly.GetManifestResourceStream("UI.wwwroot.images.generals.hochua.svg");
            if (stream != null)
            {
                stream.Seek(0, SeekOrigin.Begin);
                using var reader = new StreamReader(stream);
                _svg = await reader.ReadToEndAsync();
            }

            // Refresh data
            RefreshDataAsync(null, null);

            // Set up timer
            _timer = new System.Timers.Timer(GlobalVariable.ConfigSystem.TimerInterval);
            _timer.Elapsed += RefreshDataAsync;
            _timer.Enabled = true;

            _dotNetHelper = DotNetObjectReference.Create(this);
            await _jsRuntime.InvokeVoidAsync("setDotNetReference", _dotNetHelper);
            await LoadData();
            await LoadFT06Data();
            _isInitialized = true;

        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error in OnInitializedAsync: {ex.Message}");
        }
    }

    private async void RefreshDataAsync(object? sender, ElapsedEventArgs? e)
    {
        try
        {
            realtimeData = await _ft02Service.GetFirstOrDefaultRealTimeDisplay();
            GetAPIData();
            await _jsRuntime.InvokeVoidAsync("updateSvgFillOverflow", realtimeData);
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error in RefreshData: {ex.Message}");
        }
    }

    private void GetAPIData()
    {
        apiData = realtimeData.CalculatorValue?.GetType().GetProperties()
            .Where(p => p.Name.StartsWith("API_D_"))
            .Select(p => new KeyValuePair<string, double>(
                _localizer[p.Name.Replace("API_D_", "").Replace("_", " ")] ?? p.Name.Replace("API_D_", ""),
                Convert.ToDouble(p.GetValue(realtimeData.CalculatorValue) ?? 0)
            )).ToList();
        var locationInfo = realtimeData.Stations.FirstOrDefault(x => x.StationId == 4) ?? new();
        var Q = GetFT06DataByYValue(locationInfo.Fllow_Ho_Final ?? 0);

        _infoLine1 = $"Mực nước hiện tại: {locationInfo.Fllow_Ho_Final:N2}m; Dung tích: {Q}";
        StateHasChanged();
    }

    private async Task LoadData()
    {
        try
        {
            var response = await _ft05Service.GetAllAsync();
            if (response?.Data != null)
            {
                chartData = response.Data.Select(x => new FT05_ChartHoChuaModel
                    {
                        Id = x.Id,

                        Index = x.Index,
                        X_Value = x.X_Value,

                        L_CTDD = x.L_CTDD,
                        L_DPL = x.L_DPL,
                        L_HCCN = x.L_HCCN,
                        L_MNC = x.L_MNC,
                        L_MNDBT = x.L_MNDBT,
                        L_DPPH = x.L_DPPH,
                        L_MNKT = x.L_MNKT,
                        L_MNTK = x.L_MNTK,
                        
                        A_VungA = x.A_VungA,
                        A_VungB = x.A_VungB,
                        A_VungC = x.A_VungC,
                    }).ToList();
            }

            var ft03Response = await _ft03Service.GetByFromDateToDateAsync();
            if (ft03Response?.Data != null)
            {
                _ft03ChartData = ft03Response.Data;
            }

            await UpdateChart();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
        }
    }

    private async Task UpdateChart()
    {
        var lineProperties = typeof(FT05_ChartHoChuaModel)
            .GetProperties()
            .Where(p => p.Name.StartsWith("L_") && p.PropertyType == typeof(double?))
            .ToList();

        var areaProperties = typeof(FT05_ChartHoChuaModel)
            .GetProperties()
            .Where(p => p.Name.StartsWith("A_") && p.PropertyType == typeof(double?))
            .ToList();

        var lineDatasets = lineProperties.Select(prop => new
        {
            label = prop.Name.Replace("L_", ""),
            data = chartData
                .Where(x => x.X_Value != null && prop.GetValue(x) != null)
                .OrderBy(x => x.Index)
                .Select(x => new
                {
                    x = x.Date.ToString("yyyy-MM-ddTHH:mm:ss"),
                    y = (double)prop.GetValue(x)
                })
                .ToList(),
            borderColor = GetLineColor(prop.Name),
            borderWidth = 2,
            pointRadius = 3,
            fill = false,
            tension = 0.3,
            order = 2

        }).ToList();

        var areaDatasets = areaProperties.Select(prop => new
        {
            label = prop.Name.Replace("A_", ""),
            data = chartData
                .Where(x => x.X_Value != null && prop.GetValue(x) != null)
                .OrderBy(x => x.Index)
                .Select(x => new
                {
                    x = x.Date.ToString("yyyy-MM-ddTHH:mm:ss"),
                    y = (double)prop.GetValue(x)
                })
                .ToList(),
            backgroundColor = GetAreaColor(prop.Name),
            borderColor = GetLineColor(prop.Name),
            borderWidth = 1,
            pointRadius = 2,
            fill = true,
            tension = 0.1,
            order = 3

        }).ToList();

        var ft03Dataset = new
        {
            label = "Flow_TL_CDD",
            data = _ft03ChartData?
                .Where(x => x.X_Value != null && x.Value != null)
                .Select(x => new
                {
                    x = x.Date.ToString("yyyy-MM-ddTHH:mm:ss"),
                    y = x.Value
                })
                .ToList(),
            showLine = false,
            pointBackgroundColor = "blue",
            pointBorderColor = "blue",
            pointRadius = 2,
            pointHoverRadius = 4,
            order = 1
        };

        var allDatasets = new List<object>();
        allDatasets.AddRange(lineDatasets);
        allDatasets.AddRange(areaDatasets);
        allDatasets.Add(ft03Dataset);

        // X-axis range for region labels
        var minDate = chartData.Where(d => d.Date != default).Min(d => d.Date);
        var maxDate = chartData.Where(d => d.Date != default).Max(d => d.Date);
        var xMinStr = minDate.ToString("yyyy-MM-dd");
        var xMaxStr = maxDate.ToString("yyyy-MM-dd");

        // Compute Y bands for areas A_VungA/B/C
        var areaBands = areaProperties.Select(prop =>
        {
            var name = prop.Name.Replace("A_", "");
            var values = chartData
                .Where(x => x.X_Value != null && prop.GetValue(x) != null)
                .Select(x => (double?)prop.GetValue(x))
                .Where(v => v.HasValue)
                .Select(v => v!.Value)
                .ToList();
            double? minY = values.Any() ? values.Min() : null;
            double? maxY = values.Any() ? values.Max() : null;
            return new { name, minY, maxY };
        }).ToList();

        var chartConfig = new
        {
            type = "line",
            data = new { datasets = allDatasets },
            options = new
            {
                responsive = true,
                maintainAspectRatio = false,
                interaction = new { mode = "nearest", intersect = true },
                layout = new
                {
                    padding = new
                    {
                        top = 60
                    }
                },
                scales = new
                {
                    x = new
                    {
                        type = "time",
                        time = new
                        {
                            unit = "month",
                            displayFormats = new { day = "dd-MM" },
                            tooltipFormat = "dd/MM/yyyy HH:mm"
                        },
                        grid = new { display = true },
                        ticks = new
                        {
                            maxRotation = 45,
                            minRotation = 45
                        },
                        min = "2025-07-01",
                        max = "2026-06-30"
                    },
                    y = new
                    {
                        title = new { display = true, text = "Mực nước (m)" },
                        beginAtZero = false,
                        afterFit = "function(scale) { scale.paddingTop = 30; }"
                    }
                },
                plugins = new
                {
                    legend = new { position = "bottom" },
                    tooltip = new
                    {
                        enabled = true,
                        callbacks = new
                        {
                            label = new
                            {
                                label = "function(context) { return context.dataset.label + ': ' + context.parsed.y.toFixed(2) + 'm'; }"
                            }
                        }
                    },
                    annotation = new
                    {
                        annotations = new
                        {

                        }
                    }
                }
            }
        };

        // Regions and target datasets for value labels (for Vùng B, Vùng C lines)
        var regions = new List<object>();
        foreach (var band in areaBands)
        {
            var label = band.name switch { "VungA" => "Vùng A", "VungB" => "Vùng B", "VungC" => "Vùng C", _ => band.name };
            var bg = band.name switch { "VungA" => "rgba(196,144,120,0.10)", "VungB" => "rgba(172,210,173,0.10)", "VungC" => "rgba(224,239,246,0.10)", _ => "rgba(180,180,180,0.10)" };
            var color = band.name switch { "VungA" => "#7a6200", "VungB" => "#2e5930", "VungC" => "#2b5c73", _ => "#333" };
            regions.Add(new { label, xMin = xMinStr, xMax = xMaxStr, yMin = band.minY, yMax = band.maxY, backgroundColor = bg, color });
        }

        var meta = new
        {
            regions = regions,
            valueLabelTargets = new[] { "VungB", "VungC" }
        };

        // Attach meta to the config for JS to consume
        var finalConfig = new { chartConfig.type, chartConfig.data, chartConfig.options, meta };
        await _jsRuntime.InvokeVoidAsync("updateChart", finalConfig);
    }

    private string GetLineColor(string propertyName)
    {
        var colors = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
    {
        { "L_CTDD", "red" },
        { "L_DPL", "red" },
        { "L_HCCN", "red" },
        { "L_MNKT", "black" },
        { "L_MNTK", "black" },
        { "L_MNC", "black" },
        { "L_MNDBT", "black" },
        { "L_DPPH", "#FF49E7" },
        { "Flow_TL_CDD", "blue" },
        { "A_VungA", "red" },
        { "A_VungB", "#FF49E7" },
        { "A_VungC", "red" }
    };
        return colors.TryGetValue(propertyName, out var color) ? color : "#" + Guid.NewGuid().ToString("N").Substring(0, 6);
    }

    private string GetAreaColor(string propertyName)
    {
        var colors = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
    {
        { "A_VungA", "#C49078" },
        { "A_VungB", "#ACD2AD" },
        { "A_VungC", "#E0EFF6" },
        { "Flow_TL_CDD", "blue" }
    };
        return colors.TryGetValue(propertyName, out var color) ? color : $"rgba({new Random().Next(0, 255)}, {new Random().Next(0, 255)}, {new Random().Next(0, 255)}, 0.2)";
    }

    public void Dispose()
    {
        _timer.Elapsed -= RefreshDataAsync;
        _timer.Dispose();
    }

    private async Task LoadFT06Data()
    {
        var ft06 = await _ft06Service.GetAllAsync();
        if (ft06?.Data != null)
        {
            _ft06Data = ft06.Data;
        }
    }

    private object GetFT06DataByYValue(double yValue)
    {
        try
        {
            var integerPart = Math.Floor(yValue);
            var decimalPart = Math.Round((yValue - integerPart) * 100, 0);
            var data = _ft06Data.FirstOrDefault(x => x.Z == integerPart);
            if (data == null)
                return 0;
            return data.GetType().GetProperty($"Col{decimalPart}")?.GetValue(data);
        }
        catch (Exception ex)
        {
            return 0;
        }

    }

    [JSInvokable]
    public async Task OnChartHover(string date, double yValue)
    {
        try
        {
            var Q = GetFT06DataByYValue(yValue);
            _infoLine2 = $"X: {date}; Z: {yValue:N2}m; W: {Q}×10⁶m³";
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            _infoLine2 = $"X: {date}; Z: {yValue:N2}m; W: 0×10⁶m³";
            Console.WriteLine($"Error in OnChartHover: {ex.Message}");
        }
    }
}

