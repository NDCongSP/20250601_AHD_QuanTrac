@page "/reservoir"
@using System.Text.RegularExpressions
@using System.Timers
@using System.ComponentModel
@using System.Reflection
@using Domain.Entities
@using System.Globalization
@using UI.StaticClass
@using Application.Services
@using Microsoft.Extensions.Localization
@using Microsoft.JSInterop
@using Blazored.LocalStorage
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Authorization
@using Radzen.Blazor
@using Domain.Models
@inject IJSRuntime JSRuntime

<style>
    .rz-legend-item {
        text-wrap: nowrap !important;
    }

    .rz-series-data-label-fill {
        font-size: small;
    }

    .rz-chart-series-marker[data-value='0'] {
        display: none;
    }

    /* Equal height layout for top 3 columns */
    :root {
        --res-top-height: 365px;
    }
    .top-section .equal-height-column {
        height: var(--res-top-height);
        display: flex;
        flex-direction: column;
    }
    .column-container {
        display: flex;
        flex-direction: column;
        flex: 1 1 auto;
        min-height: 0; /* allow children to shrink */
    }
    .column-header { /* keep existing styling from markup context if any */ }
    .column-content {
        flex: 1 1 auto;
        min-height: 0;
        overflow: hidden; /* no scroll for col 1 */
    }
    .svg-container {
        height: 100%;
    }
    .svg-container svg {
        width: 100%;
        height: 100%;
    }
    .scroll-container { /* enable scroll for column 2 */
        height: 100%;
        overflow: auto;
    }
    .map-container {
        height: 100%;
    }
</style>

<div class="main-container">
    <!-- Top Section with 3 columns -->
    <div class="top-section">
        <RadzenRow class="h-100">
            <!-- First Column with Fieldset -->
            <RadzenColumn SizeXS="12" SizeLG="4" class="rz-mx-auto equal-height-column">
                <div class="column-container">
                    <div class="column-header">
                        @_localizer["Hồ chứa"]
                    </div>
                    <div class="column-content">
                        <RadzenRow class="h-100">
                            <RadzenColumn SizeXS="12" SizeMD="12" class="svg-container h-100">
                                @((MarkupString)_svg)
                            </RadzenColumn>
                        </RadzenRow>
                    </div>
                </div>
            </RadzenColumn>

            <!-- Second Column without Fieldset -->
            <RadzenColumn SizeXS="12" SizeLG="4" class="rz-mx-auto equal-height-column">
                <div class="scroll-container">
                <RadzenDataGrid Data="@apiData"
                                TItem="ReservoirDataModel" AllowFiltering="false" AllowColumnResize="true" AllowSorting="false"
                                AllowPaging="false" ShowPagingSummary="false">
                    <Columns>
                        <RadzenDataGridColumn TItem="ReservoirDataModel" Title="Tên" Property="Name" />
                        <RadzenDataGridColumn TItem="ReservoirDataModel" Title="Tức thời" Property="Value"
                                              FormatString="{0:N2}" TextAlign="TextAlign.Right" />
                        <RadzenDataGridColumn TItem="ReservoirDataModel" Title="Tổng tích luỹ" Property="Total"
                                              FormatString="{0:N2}" TextAlign="TextAlign.Right" />
                        <RadzenDataGridColumn TItem="ReservoirDataModel" Title="Thời gian" Property="CurrentDate" />
                    </Columns>
                    <EmptyTemplate>
                        <div class="rz-datatable-emptymessage" style="text-align: center; padding: 10px;">
                            @_localizer["Không có dữ liệu"]
                        </div>
                    </EmptyTemplate>
                </RadzenDataGrid>
                </div>
            </RadzenColumn>

            <!-- Third Column without Fieldset -->
            <RadzenColumn SizeXS="12" SizeLG="4" class="rz-mx-auto equal-height-column">
                <div class="map-container" style="border-top: none; height: 100%;">
                    <iframe src="https://vrain.vn/61/overview?public_map=windy"
                            style="width: 100%; height: 100%; border: none; border-radius: 0 0 4px 4px;" allowfullscreen>
                    </iframe>
                </div>
            </RadzenColumn>
        </RadzenRow>
    </div>

    <!-- Bottom Section with Stacked Area Chart -->
    <div class="bottom-section">
        <div class="chart-wrapper">
            <div class="chart-header" style="font-weight: bold;">
                Zmndbt (m): 24.40 &nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Wmndbt (10<sup>6</sup>m<sup>3</sup>): 1580.80
            </div>
            <div id="chartContainer">
                <div id="infoLine1" class="chart-label">
                    @_infoLine1
                </div>
                <div id="infoLine2" class="chart-label">
                    @_infoLine2
                </div>
                <canvas id="reservoirChart" height="400"></canvas>
            </div>
        </div>
    </div>
</div>

@code {
    private RadzenChart? _chart;
    private string _svg, _infoLine1, _infoLine2;
    private System.Timers.Timer _timer = new();
    private List<FT05_ChartHoChuaModel> chartData = new();
    private List<ReservoirDataModel> apiData = new();

    private List<FT03DataPoint> _ft03ChartData = new();
    private RealtimeDisplayModel realtimeData = new();
    private DotNetObjectReference<Index> _dotNetHelper;
    private bool _isInitialized = false;
    private List<FT06_InterpolationTable> _ft06Data = new();
    public class ReservoirDataModel
    {
        public string Name { get; set; }
        public double Value { get; set; }
        public double Total { get; set; }
        public string CurrentDate { get; set; }
    }
    protected override async Task OnInitializedAsync()
    {
        try
        {
            LayoutState.SetTitle(_localizer["HoChua"]);
            await base.OnInitializedAsync();

            // Load SVG
            using var stream = this.GetType().Assembly.GetManifestResourceStream("UI.wwwroot.images.generals.hochua.svg");
            if (stream != null)
            {
                stream.Seek(0, SeekOrigin.Begin);
                using var reader = new StreamReader(stream);
                _svg = await reader.ReadToEndAsync();
            }

            // Refresh data
            RefreshDataAsync(null, null);

            // Set up timer
            _timer = new System.Timers.Timer(GlobalVariable.ConfigSystem.TimerInterval);
            _timer.Elapsed += RefreshDataAsync;
            _timer.Enabled = true;

            _dotNetHelper = DotNetObjectReference.Create(this);
            await _jsRuntime.InvokeVoidAsync("setDotNetReference", _dotNetHelper);
            await LoadData();
            await LoadFT06Data();
            _isInitialized = true;

        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error in OnInitializedAsync: {ex.Message}");
        }
    }

    private async void RefreshDataAsync(object? sender, ElapsedEventArgs? e)
    {
        try
        {
            realtimeData = await _ft02Service.GetFirstOrDefaultRealTimeDisplay();
            GetAPIData();
            // await _jsRuntime.InvokeVoidAsync("updateSvgFillOverflow", realtimeData);
            await _jsRuntime.InvokeVoidAsync("updateSvgHoChua", realtimeData);
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error in RefreshData: {ex.Message}");
        }
    }

    private void GetAPIData()
    {
        var currentDate = DateTime.Now.ToString("dd/MM/yyyy");

        apiData = realtimeData.CalculatorValue?.GetType().GetProperties()
            .Where(p => p.Name.StartsWith("API_D_") && !p.Name.EndsWith("_Total"))
            .Select(p =>
            {
                var name = _localizer[p.Name.Replace("API_D_", "").Replace("_", " ")] ?? p.Name.Replace("API_D_", "");
                var value = Convert.ToDouble(p.GetValue(realtimeData.CalculatorValue) ?? 0);

                // Tìm field tương ứng có _Total
                var totalProperty = realtimeData.CalculatorValue.GetType().GetProperty(p.Name + "_Total");
                var total = totalProperty != null ? Convert.ToDouble(totalProperty.GetValue(realtimeData.CalculatorValue) ?? 0) : 0;

                return new ReservoirDataModel
                {
                    Name = name,
                    Value = value,
                    Total = total,
                    CurrentDate = currentDate
                };
            }).ToList();

        var locationInfo = realtimeData.Stations.FirstOrDefault(x => x.StationId == 4) ?? new();
        var Q = GetFT06DataByYValue(locationInfo.Fllow_Ho_Final ?? 0);

        _infoLine1 = $"Mực nước hiện tại: {locationInfo.Fllow_Ho_Final:N2}m; Dung tích: {Q}";
        StateHasChanged();
    }

    private async Task LoadData()
    {
        try
        {
            var response = await _ft05Service.GetAllAsync();
            if (response?.Data != null)
            {
                chartData = response.Data.Select(x => new FT05_ChartHoChuaModel
                {
                    Id = x.Id,

                    Index = x.Index,
                    X_Value = x.X_Value,

                    L_CTDD = x.L_CTDD,
                    L_DPL = x.L_DPL,
                    L_HCCN = x.L_HCCN,
                    L_MNC = x.L_MNC,
                    L_MNDBT = x.L_MNDBT,
                    L_DPPH = x.L_DPPH,
                    L_MNKT = x.L_MNKT,
                    L_MNTK = x.L_MNTK,

                    A_VungA = x.A_VungA,
                    A_VungB = x.A_VungB,
                    A_VungC = x.A_VungC,
                }).ToList();
            }

            var ft03Response = await _ft03Service.GetByFromDateToDateAsync();
            if (ft03Response?.Data != null)
            {
                _ft03ChartData = ft03Response.Data;
            }

            await UpdateChart();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
        }
    }

    private async Task UpdateChart()
    {
        var lineProperties = typeof(FT05_ChartHoChuaModel)
            .GetProperties()
            .Where(p => p.Name.StartsWith("L_") && p.PropertyType == typeof(double?))
            .ToList();

        var areaProperties = typeof(FT05_ChartHoChuaModel)
            .GetProperties()
            .Where(p => p.Name.StartsWith("A_") && p.PropertyType == typeof(double?))
            .ToList();

        string GetDisplayName(string propertyName)
        {
            var propInfo = typeof(FT05_ChartHoChua).GetProperty(propertyName);
            var dn = propInfo?.GetCustomAttribute<DisplayNameAttribute>()?.DisplayName;
            if (!string.IsNullOrWhiteSpace(dn)) return dn!;
            return propertyName.StartsWith("L_") || propertyName.StartsWith("A_")
                ? propertyName.Substring(2)
                : propertyName;
        }

        var lineDatasets = lineProperties.Select(prop => new
        {
            label = GetDisplayName(prop.Name),
            data = chartData
                .Where(x => x.X_Value != null && prop.GetValue(x) != null)
                .OrderBy(x => x.Index)
                .Select(x => new
                {
                    x = x.Date.ToString("yyyy-MM-ddTHH:mm:ss"),
                    y = (double)prop.GetValue(x)
                })
                .ToList(),
            borderColor = GetLineColor(prop.Name),
            borderWidth = 2,
            pointRadius = 3,
            fill = false,
            tension = 0.3,
            order = 2

        }).ToList();

        var areaDatasets = areaProperties.Select(prop => new
        {
            label = GetDisplayName(prop.Name),
            data = chartData
                .Where(x => x.X_Value != null && prop.GetValue(x) != null)
                .OrderBy(x => x.Index)
                .Select(x => new
                {
                    x = x.Date.ToString("yyyy-MM-ddTHH:mm:ss"),
                    y = (double)prop.GetValue(x)
                })
                .ToList(),
            backgroundColor = GetAreaColor(prop.Name),
            borderColor = GetLineColor(prop.Name),
            borderWidth = 1,
            pointRadius = 2,
            fill = true,
            tension = 0.1,
            order = 3

        }).ToList();

        var ft03Dataset = new
        {
            label = "Flow_Ho_Final",
            data = _ft03ChartData?
                .Where(x => x.X_Value != null && x.Value != null)
                .Select(x => new
                {
                    x = x.Date.ToString("yyyy-MM-ddTHH:mm:ss"),
                    y = x.Value
                })
                .ToList(),
            showLine = false,
            pointBackgroundColor = "blue",
            pointBorderColor = "blue",
            pointRadius = 2,
            pointHoverRadius = 4,
            order = 1
        };

        var allDatasets = new List<object>();
        allDatasets.AddRange(lineDatasets);
        allDatasets.AddRange(areaDatasets);
        allDatasets.Add(ft03Dataset);

        // X-axis range for region labels
        var minDate = chartData.Where(d => d.Date != default).Min(d => d.Date);
        var maxDate = chartData.Where(d => d.Date != default).Max(d => d.Date);
        var xMinStr = minDate.ToString("yyyy-MM-dd");
        var xMaxStr = maxDate.ToString("yyyy-MM-dd");

        // Compute representative thresholds for areas A_VungA/B/C
        var areaBands = areaProperties.Select(prop =>
        {
            var name = prop.Name.Replace("A_", "");
            var values = chartData
                .Where(x => x.X_Value != null && prop.GetValue(x) != null)
                .Select(x => (double?)prop.GetValue(x))
                .Where(v => v.HasValue)
                .Select(v => v!.Value)
                .OrderBy(v => v)
                .ToList();
            double? minY = values.Any() ? values.Min() : null;
            double? maxY = values.Any() ? values.Max() : null;
            double? avgY = values.Any() ? values.Average() : null;
            double? medianY = values.Any() ? values[values.Count / 2] : null;
            // prefer median to avoid outliers; fallback average
            var refY = medianY ?? avgY;
            return new { name, minY, maxY, refY };
        }).ToList();

        // Global Y min for axis (start ticks from min instead of 0)
        var allYValues = new List<double>();
        foreach (var prop in lineProperties)
        {
            var vals = chartData
                .Where(x => x.X_Value != null && prop.GetValue(x) != null)
                .Select(x => (double?)prop.GetValue(x))
                .Where(v => v.HasValue)
                .Select(v => v!.Value);
            allYValues.AddRange(vals);
        }
        foreach (var prop in areaProperties)
        {
            var vals = chartData
                .Where(x => x.X_Value != null && prop.GetValue(x) != null)
                .Select(x => (double?)prop.GetValue(x))
                .Where(v => v.HasValue)
                .Select(v => v!.Value);
            allYValues.AddRange(vals);
        }
        if (_ft03ChartData != null && _ft03ChartData.Any())
        {
            var vals = _ft03ChartData
                .Where(x => x.Value != null)
                .Select(x => x.Value!.Value);
            allYValues.AddRange(vals);
        }

        // Use the smallest positive (> 0) value for Y min; ignore zeros
        var positiveYValues = allYValues.Where(v => v > 0).ToList();
        var yMinAll = positiveYValues.Any() ? positiveYValues.Min() : (allYValues.Any() ? allYValues.Min() : 0d);
        var yMaxAll = allYValues.Any() ? allYValues.Max() : yMinAll + 10d;
        var yMinTick = Math.Floor(yMinAll); // align ticks nicely with stepSize=1
        var yMaxTick = Math.Ceiling(yMaxAll);

        var chartConfig = new
        {
            type = "line",
            data = new { datasets = allDatasets },
            options = new
            {
                responsive = true,
                maintainAspectRatio = false,
                interaction = new { mode = "nearest", intersect = true },
                layout = new
                {
                    padding = new
                    {
                        top = 60
                    }
                },
                scales = new
                {
                    x = new
                    {
                        type = "time",
                        time = new
                        {
                            unit = "month",
                            displayFormats = new { day = "dd/MM" },
                            tooltipFormat = "dd/MM/yyyy HH:mm"
                        },
                        grid = new { display = true },
                        ticks = new
                        {
                            maxRotation = 45,
                            minRotation = 45,
                            callback = "function(value){ return luxon.DateTime.fromMillis(value).toFormat('dd/MM'); }"
                        },
                        min = "2025-07-01",
                        max = "2026-06-30"
                    },
                    y = new
                    {
                        title = new { display = true, text = "Mực nước (m)" },
                        beginAtZero = false,
                        min = yMinTick,
                        ticks = new
                        {
                            stepSize = 1,
                            autoSkip = false,
                            padding = 12,
                            font = new { size = 13 },
                            callback = "function(value){ return Number(value).toFixed(1); }"
                        },
                        grace = "10%",
                        afterFit = "function(scale) { scale.paddingTop = 30; scale.width = scale.width + 28; }"
                    }
                },
                plugins = new
                {
                    legend = new { position = "bottom" },
                    tooltip = new
                    {
                        enabled = true,
                        callbacks = new
                        {
                            label = new
                            {
                                label = "function(context) { return context.dataset.label + ': ' + context.parsed.y.toFixed(2) + 'm'; }"
                            }
                        }
                    },
                    annotation = new
                    {
                        annotations = new
                        {

                        }
                    }
                }
            }
        };

        // Regions and target datasets for value labels (for Vùng B, Vùng C lines)
        // Determine thresholds using refY values
        var yA = areaBands.FirstOrDefault(b => b.name.Equals("VungA", StringComparison.OrdinalIgnoreCase))?.refY;
        var yB = areaBands.FirstOrDefault(b => b.name.Equals("VungB", StringComparison.OrdinalIgnoreCase))?.refY;
        var yC = areaBands.FirstOrDefault(b => b.name.Equals("VungC", StringComparison.OrdinalIgnoreCase))?.refY;
        // Sort thresholds ascending, ignore nulls
        var thresholds = new List<double>();
        if (yA.HasValue) thresholds.Add(yA.Value);
        if (yB.HasValue) thresholds.Add(yB.Value);
        if (yC.HasValue) thresholds.Add(yC.Value);
        thresholds = thresholds.Distinct().OrderBy(v => v).ToList();

        double lower1 = yMinTick;
        double mid1 = thresholds.Count > 0 ? thresholds[0] : yMinTick + 1;
        double mid2 = thresholds.Count > 1 ? thresholds[1] : mid1 + 1;
        double upper = yMaxTick;

        var regions = new List<object>
        {
            new { label = "Vùng C", xMin = xMinStr, xMax = xMaxStr, yMin = lower1, yMax = mid1, backgroundColor = "rgba(224,239,246,0.10)", color = "red", showLabel = true },
            new { label = "Vùng A", xMin = xMinStr, xMax = xMaxStr, yMin = mid1, yMax = mid2, backgroundColor = "rgba(196,144,120,0.10)", color = "red", showLabel = true },
            new { label = "Vùng B", xMin = xMinStr, xMax = xMaxStr, yMin = mid2, yMax = upper, backgroundColor = "rgba(172,210,173,0.10)", color = "#2e5930", showLabel = true }
        };

        var labelB = GetDisplayName("A_VungB");
        var labelC = GetDisplayName("A_VungC");

        var meta = new
        {
            regions = regions,
            valueLabelTargets = new[] { labelB, labelC },
            chartHeight = 560
        };

        // Attach meta to the config for JS to consume
        var finalConfig = new { chartConfig.type, chartConfig.data, chartConfig.options, meta };
        await _jsRuntime.InvokeVoidAsync("updateChart", finalConfig);
    }

    private string GetLineColor(string propertyName)
    {
        var colors = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
    {
        { "L_CTDD", "red" },
        { "L_DPL", "red" },
        { "L_HCCN", "red" },
        { "L_MNKT", "black" },
        { "L_MNTK", "black" },
        { "L_MNC", "black" },
        { "L_MNDBT", "black" },
        { "L_DPPH", "#FF49E7" },
        { "Flow_Ho_Final", "blue" },
        { "A_VungA", "red" },
        { "A_VungB", "#FF49E7" },
        { "A_VungC", "red" }
    };
        return colors.TryGetValue(propertyName, out var color) ? color : "#" + Guid.NewGuid().ToString("N").Substring(0, 6);
    }

    private string GetAreaColor(string propertyName)
    {
        var colors = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
    {
        { "A_VungA", "#C49078" },
        { "A_VungB", "#ACD2AD" },
        { "A_VungC", "#E0EFF6" },
        { "Flow_Ho_Final", "blue" }
    };
        return colors.TryGetValue(propertyName, out var color) ? color : $"rgba({new Random().Next(0, 255)}, {new Random().Next(0, 255)}, {new Random().Next(0, 255)}, 0.2)";
    }

    public void Dispose()
    {
        _timer.Elapsed -= RefreshDataAsync;
        _timer.Dispose();
    }

    private async Task LoadFT06Data()
    {
        var ft06 = await _ft06Service.GetAllAsync();
        if (ft06?.Data != null)
        {
            _ft06Data = ft06.Data;
        }
    }

    private object GetFT06DataByYValue(double yValue)
    {
        try
        {
            var integerPart = Math.Floor(yValue);
            var decimalPart = Math.Round((yValue - integerPart) * 100, 0);
            var data = _ft06Data.FirstOrDefault(x => x.Z == integerPart);
            if (data == null)
                return 0;
            return data.GetType().GetProperty($"Col{decimalPart}")?.GetValue(data);
        }
        catch (Exception ex)
        {
            return 0;
        }

    }

    [JSInvokable]
    public async Task OnChartHover(string date, double yValue)
    {
        try
        {
            var Q = GetFT06DataByYValue(yValue);
            _infoLine2 = $"X: {date}; Z: {yValue:N2}m; W: {Q:N2}×10⁶m³";
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            _infoLine2 = $"X: {date}; Z: {yValue:N2}m; W: 0×10⁶m³";
            Console.WriteLine($"Error in OnChartHover: {ex.Message}");
        }
    }
}

