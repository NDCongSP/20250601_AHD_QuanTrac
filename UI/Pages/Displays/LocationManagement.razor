@page "/location-management"
@using Domain

<RadzenRow Gap="1rem" Class="padding-body-content">
    <RadzenColumn SizeXS="12" SizeMD="12">
        <RadzenStack>
            <RadzenFieldset Text="@_localizer["Gate.Management"]">
                <RadzenStack Orientation="Radzen.Orientation.Vertical" JustifyContent="Radzen.JustifyContent.Center" 
                           AlignItems="AlignItems.Stretch" Gap="5px">
                    <RadzenStack Orientation="Radzen.Orientation.Horizontal" 
                               JustifyContent="Radzen.JustifyContent.End"
                               AlignItems="AlignItems.Center" 
                               Gap="1rem" 
                               Wrap="Radzen.FlexWrap.Wrap">
                        <RadzenButton Click="@AddNewItem" 
                                    Variant="Variant.Flat" 
                                    Shade="Shade.Dark"
                                    Text="@_localizer["Create"]" 
                                    Icon="add_circle" 
                                    ButtonStyle="ButtonStyle.Success" />
                    </RadzenStack>

                    <RadzenDataGrid Style="width: 100%;" 
                                  Data="@Locations"
                                  TItem="LocationInfoModel"
                                  AllowFiltering="true"
                                  FilterPopupRenderMode="PopupRenderMode.OnDemand" 
                                  AllowPaging="true" 
                                  PageSize="20" 
                                  PageSizeText="@_localizer["items per page"]" 
                                  AllowSorting="true"
                                  AllowColumnResize="true" 
                                  AllowColumnPicking="false"
                                  AllowGrouping="false" 
                                  EmptyText="@_localizer["No records to display."]"
                                  GridLines="Radzen.DataGridGridLines.Both" 
                                  AllowAlternatingRows="false">
                        <Columns>
                            <RadzenDataGridColumn TItem="LocationInfoModel"
                                                  Width="100px" 
                                                Title="#" 
                                                TextAlign="TextAlign.Center">
                                <Template Context="data">
                                    @(Locations.IndexOf(data) + 1)
                                </Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn TItem="LocationInfoModel"
                                                  Width="300px" 
                                                Property="Name" 
                                                Title="@_localizer["Name"]" 
                                                TextAlign="TextAlign.Left" />

                            <RadzenDataGridColumn TItem="LocationInfoModel"
                                                  Width="400px" 
                                                Property="Description" 
                                                Title="@_localizer["Description"]" 
                                                TextAlign="TextAlign.Left" />

                            <RadzenDataGridColumn TItem="LocationInfoModel"
                                                  Width="200px" 
                                                Title="@_localizer["Actions"]" 
                                                TextAlign="TextAlign.Center"
                                                Filterable="false" 
                                                Sortable="false">
                                <Template Context="data">
                                    <RadzenStack Orientation="Radzen.Orientation.Horizontal" 
                                               JustifyContent="Radzen.JustifyContent.Center" 
                                               Gap="0.5rem">
                                        <RadzenButton ButtonStyle="ButtonStyle.Info" 
                                                    Variant="Variant.Text"
                                                    Icon="visibility" 
                                                    Size="ButtonSize.Small"
                                                    Click="@(args => ViewItem(data))" 
                                                    Class="p-0" />
                                        <RadzenButton ButtonStyle="ButtonStyle.Danger" 
                                                    Variant="Variant.Text"
                                                    Icon="delete" 
                                                    Size="ButtonSize.Small"
                                                    Click="@(args => DeleteItem(data))" 
                                                    Class="p-0" />
                                    </RadzenStack>
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                </RadzenStack>
            </RadzenFieldset>
        </RadzenStack>
    </RadzenColumn>
</RadzenRow>
