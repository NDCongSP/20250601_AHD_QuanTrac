@page "/operation-board"
@using Application.Services
@using Domain.Entities
<h3>FileMnagerComponent</h3>

@inject IFT08 _ft08Service
@using Microsoft.AspNetCore.Components.Forms

<div class="d-flex" style="gap:12px;">
    <div style="width:320px; min-width:280px; max-width:420px; border:1px solid #ddd; border-radius:6px; padding:8px; height:82vh; overflow:auto;">
        <div class="d-flex mb-2" style="gap:6px;">
            <input @bind="search" @bind:event="oninput" class="form-control form-control-sm" placeholder="Tìm file..." />
            <button class="btn btn-sm btn-outline-secondary" @onclick="Reload">↻</button>
        </div>

        @if (loadingList)
        {
            <div>Đang tải danh sách...</div>
        }
        else if (groups?.Count > 0)
        {
            @foreach (var g in groups)
            {
                var filtered = FilterFiles(g.Files);
                <div class="mb-2">
                    <div class="fw-bold" style="cursor:pointer;" @onclick="() => Toggle(g)">
                        <span>@(g.Expanded ? "▼" : "▶")</span>
                        <span title="@g.Path">@Shorten(g.Path)</span>
                        <span class="text-muted"> (@filtered.Count)</span>
                    </div>
                    @if (g.Expanded)
                    {
                        <ul class="mt-1" style="list-style:none; padding-left:14px;">
                            @foreach (var f in filtered)
                            {
                                var full = BuildFullPath(f);
                                <li style="cursor:pointer;" @onclick="() => LoadPdf(full)">
                                    📄 @f.FileName
                                </li>
                            }
                        </ul>
                    }
                </div>
            }
        }
        else
        {
            <div>Không có dữ liệu.</div>
        }
    </div>

    <div class="flex-fill" style="height:82vh;">
        <div class="mb-2 d-flex align-items-center" style="gap:8px;">
            <input @bind="filePath" class="form-control" placeholder="Đường dẫn đầy đủ đến file PDF" />
            <button class="btn btn-primary" @onclick="() => LoadPdf(filePath)" disabled="@loading">Đọc PDF</button>
            @if (loading)
            {
                <span>Đang tải...</span>
            }
        </div>

        <div class="mb-3" style="border:1px dashed #bbb; padding:10px; border-radius:6px;">
            <div class="fw-bold mb-2">Tải lên PDF</div>
            <div class="d-flex" style="gap:8px;">
                <InputFile OnChange="OnFileSelected" accept="application/pdf" />
                <input @bind="uploadFolder" class="form-control" placeholder="Thư mục lưu (PathFile)" style="max-width:420px;" />
                <button class="btn btn-success" @onclick="UploadSelectedFile" disabled="@(uploading || selectedFileData == null)">Tải lên</button>
            </div>
            @if (!string.IsNullOrWhiteSpace(uploadError))
            {
                <div class="text-danger mt-2">@uploadError</div>
            }
            @if (!string.IsNullOrWhiteSpace(uploadInfo))
            {
                <div class="text-success mt-2">@uploadInfo</div>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(error))
        {
            <div class="text-danger">@error</div>
        }

        @if (!string.IsNullOrWhiteSpace(base64Pdf))
        {
            <iframe style="width:100%;height:100%; border:1px solid #eee; border-radius:6px;" src="data:application/pdf;base64,@base64Pdf"></iframe>
        }
        else
        {
            <div class="text-muted">Chọn một file PDF ở cây bên trái để xem.</div>
        }
    </div>
</div>

@code {
    string filePath;
    string base64Pdf;
    string error;
    bool loading;
    bool loadingList;
    string search;

    // Upload state
    IBrowserFile selectedFile;
    string selectedFileName;
    string selectedFileData; // base64
    string uploadFolder;
    bool uploading;
    string uploadError;
    string uploadInfo;

    List<FT08_FilesManagement> files = new();
    List<GroupItem> groups = new();

    class GroupItem
    {
        public string Path { get; set; }
        public bool Expanded { get; set; } = true;
        public List<FT08_FilesManagement> Files { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await Reload();
    }

    async Task Reload()
    {
        loadingList = true;
        error = null;
        base64Pdf = null;
        try
        {
            var res = await _ft08Service.GetAllAsync();
            if (res != null && res.Succeeded && res.Data != null)
            {
                files = res.Data;
                groups = files
                    .GroupBy(x => x.PathFile ?? "")
                    .OrderBy(g => g.Key)
                    .Select(g => new GroupItem
                    {
                        Path = g.Key,
                        Files = g.OrderBy(x => x.FileName).ToList(),
                        Expanded = true
                    })
                    .ToList();
            }
            else
            {
                error = res?.Messages?.FirstOrDefault() ?? "Không tải được danh sách.";
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            loadingList = false;
        }
    }

    List<FT08_FilesManagement> FilterFiles(List<FT08_FilesManagement> input)
    {
        if (string.IsNullOrWhiteSpace(search)) return input;
        var q = search.Trim();
        return input.Where(x => (x.FileName ?? "").Contains(q, StringComparison.OrdinalIgnoreCase)).ToList();
    }

    void Toggle(GroupItem g)
    {
        g.Expanded = !g.Expanded;
    }

    async Task LoadPdf(string fullPath)
    {
        error = null;
        base64Pdf = null;
        if (string.IsNullOrWhiteSpace(fullPath))
        {
            error = "Vui lòng nhập đường dẫn tệp PDF.";
            return;
        }

        loading = true;
        try
        {
            var res = await _ft08Service.GetPdfAsBase64Async(fullPath);
            if (res != null && res.Succeeded && !string.IsNullOrEmpty(res.Data))
            {
                base64Pdf = res.Data;
            }
            else
            {
                error = (res != null && res.Messages != null && res.Messages.Count > 0)
                    ? res.Messages[0]
                    : "Không thể đọc PDF.";
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }

    string BuildFullPath(FT08_FilesManagement f)
    {
        if (string.IsNullOrWhiteSpace(f?.PathFile)) return f?.FileName ?? string.Empty;
        if (string.IsNullOrWhiteSpace(f?.FileName)) return f.PathFile;
        // Tránh lặp dấu \\ khi PathFile đã có dấu cuối
        if (f.PathFile.EndsWith("\\") || f.PathFile.EndsWith("/"))
            return $"{f.PathFile}{f.FileName}";
        return $"{f.PathFile}\\{f.FileName}";
    }

    string Shorten(string input)
    {
        if (string.IsNullOrEmpty(input)) return "(trống)";
        // Rút gọn cho dễ nhìn: lấy phần đuôi 50 ký tự
        return input.Length > 80 ? "…" + input[^80..] : input;
    }

    async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        uploadError = uploadInfo = null;
        selectedFileData = null;
        selectedFileName = null;
        selectedFile = e.File;
        if (selectedFile == null)
        {
            uploadError = "Chưa chọn file.";
            return;
        }
        if (!string.Equals(selectedFile.ContentType, "application/pdf", StringComparison.OrdinalIgnoreCase))
        {
            uploadError = "Vui lòng chọn file PDF.";
            return;
        }
        selectedFileName = selectedFile.Name;
        try
        {
            using var ms = new MemoryStream();
            await selectedFile.OpenReadStream(50 * 1024 * 1024).CopyToAsync(ms);
            selectedFileData = Convert.ToBase64String(ms.ToArray());
        }
        catch (Exception ex)
        {
            uploadError = ex.Message;
        }
    }

    async Task UploadSelectedFile()
    {
        uploadError = uploadInfo = null;
        if (selectedFile == null || string.IsNullOrEmpty(selectedFileData))
        {
            uploadError = "Chưa chọn file PDF.";
            return;
        }
        if (string.IsNullOrWhiteSpace(uploadFolder))
        {
            uploadError = "Vui lòng nhập thư mục lưu (PathFile).";
            return;
        }
        uploading = true;
        try
        {
            var req = new Application.DTOs.Request.UploadPdfFileRequest
            {
                PathFile = uploadFolder,
                FileName = selectedFileName,
                Base64 = selectedFileData
            };
            var res = await _ft08Service.UploadPdfFileAsync(req);
            if (res != null && res.Succeeded && res.Data != null)
            {
                uploadInfo = "Tải lên thành công.";
                // Cập nhật UI danh sách
                await Reload();
            }
            else
            {
                uploadError = res?.Messages?.FirstOrDefault() ?? "Tải lên thất bại.";
            }
        }
        catch (Exception ex)
        {
            uploadError = ex.Message;
        }
        finally
        {
            uploading = false;
        }
    }
}
