@page "/"
@using Microsoft.AspNetCore.Components
@attribute [Authorize(Policy = "Admin")]

<style>
    .homepage-container {
        position: relative;
        width: 100%;
        height: calc(100vh - 87px);
        /* Adjust based on header height */
        overflow: hidden;
    }

    .background-image {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-image: url('images/generals/Main.bmp');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        /* filter: brightness(0.8); */
        z-index: 1;
    }

    .content-overlay {
        position: relative;
        z-index: 2;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        color: white;
        text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.5);
        justify-content: flex-start;
    }

    .logo-container {
        max-width: 150px;
        width: 100%;
    }

    .logo {
        width: 100%;
        height: auto;
        max-height: 90px;
        object-fit: contain;
    }

    .welcome-text {
        font-size: 2.5rem;
        font-weight: 500;
        margin: auto;
    }

    .subtitle {
        font-size: 1.2rem;
        max-width: 800px;
        line-height: 1.6;
        margin-bottom: 2rem;
    }

    .features {
        display: flex;
        gap: 2rem;
        margin-top: 2rem;
        flex-wrap: wrap;
        justify-content: center;
    }

    .feature-item {
        background: rgb(0 0 0 / 46%);
        backdrop-filter: blur(5px);
        padding: 1.5rem;
        border-radius: 8px;
        max-width: 250px;
        transition: transform 0.3s ease;
    }

    .feature-item:hover {
        transform: translateY(-5px);
    }

    .feature-icon {
        font-size: 2rem;
        margin-bottom: 1rem;
        color: var(--rz-primary);
    }

    .header {
        background-color: #fff;
        color: #052077;
        padding: 0.5rem;
        width: 100%;
        display: flex;
        text-align: center;
        justify-content: space-between;
    }

    .title {
        font-size: 2rem;
        font-weight: bold;
        margin-bottom: 1rem;
    }
</style>

<div class="homepage-container">
    <div class="background-image"></div>
    <div class="content-overlay">
   @*      <div class="header">
            <div class="logo-container">
                <img src="images/generals/logo-removebg-preview.png" alt="Logo" class="logo" />
            </div>
            <h1 class="welcome-text">CÔNG TY TNHH MTV KHAI THÁC THỦY LỢI MIỀN NAM</h1>
        </div> *@
        @* <p class="subtitle">Giải pháp toàn diện cho việc giám sát và quản lý hồ chứa thông minh, đảm bảo an toàn và hiệu
            quả hoạt động.</p> *@

        <div class="features">
            <div class="feature-item">
                <div class="feature-icon">
                    <i class="fas fa-tint"></i>
                </div>
                <h3>Theo dõi mực nước</h3>
                <p>Giám sát thời gian thực mực nước các hồ chứa</p>
            </div>
            <div class="feature-item">
                <div class="feature-icon">
                    <i class="fas fa-chart-line"></i>
                </div>
                <h3>Báo cáo & Phân tích</h3>
                <p>Dữ liệu chi tiết và báo cáo tự động</p>
            </div>
            <div class="feature-item">
                <div class="feature-icon">
                    <i class="fas fa-bell"></i>
                </div>
                <h3>Cảnh báo thông minh</h3>
                <p>Nhận thông báo kịp thời khi có sự cố</p>
            </div>
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        LayoutState.SetTitle("CÔNG TY TNHH MTV KHAI THÁC THỦY LỢI MIỀN NAM");
    }
}
