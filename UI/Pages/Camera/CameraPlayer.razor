    // private string hlsStreamUrl2 = "http://14.224.229.6:8888/Cam2/index.m3u8";
    // private string hlsStreamUrl3 = "http://14.224.229.6:8888/Cam3/index.m3u8";
    // private string hlsStreamUrl4 = "http://14.224.229.6:8888/Cam4/index.m3u8";
    // private string hlsStreamUrl5 = "http://14.224.229.6:8888/Cam5/index.m3u8";
    // private string hlsStreamUrl6 = "http://14.224.229.6:8888/Cam6/index.m3u8";
    // private string hlsStreamUrl7 = "http://14.224.229.6:8888/Cam7/index.m3u8";
    // private string hlsStreamUrl8 = "http://14.224.229.6:8888/Cam8/index.m3u8";
    // private string hlsStreamUrl9 = "http://14.224.229.6:8888/Cam9/index.m3u8";
    // private string hlsStreamUrl10 = "http://14.224.229.6:8888/Cam10/index.m3u8";

    private bool _isDataLoaded = false;
    private bool _jsInitialized = false;
    private List<CameraConfigModel>? _cameraConfigs = new List<CameraConfigModel>();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await _ft01Service.GetConfigAsync();
            if (result.Succeeded && result.Data != null)
            {
                _cameraConfigs = result.Data.CameraConfigs?
                    .Where(c => c != null && c.Actived && !string.IsNullOrWhiteSpace(c.HlsStreamUrl))
                    .ToList() ?? new List<CameraConfigModel>();

            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Lỗi khi tải cấu hình camera: {ex.Message}");
            _cameraConfigs = new List<CameraConfigModel>();
        }

        // BÁO LÀ ĐÃ TẢI XONG
        _isDataLoaded = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Sửa điều kiện if ở đây
        if (_isDataLoaded && !_jsInitialized)
        {
            // Đặt cờ này ngay lập tức để nó không chạy lại
            _jsInitialized = true;

            if (_cameraConfigs == null || !_cameraConfigs.Any())
            {
                Console.WriteLine("DEBUG: Data đã tải xong, nhưng _cameraConfigs RỖNG.");
                return;
            }

            // Gọi hàm JavaScript để tải video
            foreach (var item in _cameraConfigs)
            {
                await _jsRuntime.InvokeVoidAsync("loadHlsPlayer", $"Cam{item.CameraId}", item.HlsStreamUrl);
            }
        }
    }
}