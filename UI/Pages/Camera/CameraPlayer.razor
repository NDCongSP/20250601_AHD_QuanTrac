@page "/camera"
@inject IStringLocalizer<CommonResources> _localizer

@if (!_isDataLoaded)
{
    <RadzenText Text=@_localizer["Loading"]></RadzenText>
}
else
{
    @* <video id="my-camera-video10" controls autoplay muted style="width: 100%; max-width: 800px;"></video> *@
    <div class="row">
        @{
            var index = 0;
        }
        @foreach (var cam in _cameraConfigs!)
        {
            <div class="col-12 col-md-6 col-lg-3 rz-mb-3">
                <RadzenCard Style="height: 100%;">
                    <RadzenStack Orientation="Orientation.Vertical" Gap="6px">
                        <RadzenText TextStyle="TextStyle.Subtitle1" Class="rz-mb-1">@(!string.IsNullOrWhiteSpace(cam.CameraTitle) ? cam.CameraTitle : "Camera")</RadzenText>
                        <video id="@($"Cam{cam.CameraId}")" controls autoplay muted style="width: 100%; height: 260px; background:#000;"></video>
                    </RadzenStack>
                </RadzenCard>
            </div>
        }
    </div>
}

@code {
    // Đây là đường dẫn HLS từ MediaMTX (Bước 2)
