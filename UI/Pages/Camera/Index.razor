        //     foreach (var cam in _cameraConfigs)
        //     {
        //         index++;
        //         var id = $"cam-video-{index}";
        //         try
        //         {
        //             await _jsRuntime.InvokeVoidAsync("loadHlsPlayer", id, cam.HlsStreamUrl1);
        //         }
        //         catch (Exception ex)
        //         {
        //             Console.WriteLine($"Error loading HLS player for {id}: {ex.Message}");
        //         }
        //     }
        // }
    }
}


