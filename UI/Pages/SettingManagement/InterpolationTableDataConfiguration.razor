@page "/interpolation-table-data-configuration"
@using Radzen
@using Radzen.Blazor
@using Microsoft.AspNetCore.Authorization
@using Microsoft.Extensions.Localization
@using Domain
@using Application.Services
@attribute [Authorize(Policy = "Admin")]

<style>
    .interpolation-group-0 {
        background-color: #f8f9fa;
        color: black !important;
    }
    .interpolation-group-1 {
        background-color: #e9ecef;
        color: black !important;
    }
    .edit-cell {
        background-color: #ffa500 !important; /* Orange color when clicked */
        color: black !important;
    }
    .rz-textbox[disabled] {
        opacity: 1;
        color: black !important;
        background-color: inherit;
        cursor: default;
        text-align: center;
    }
    .increment-helper {
        font-size: 0.8em;
        color: #666;
        background: rgba(255, 255, 255, 0.7);
        padding: 2px 0;
        border-radius: 3px;
        text-align: center;
        margin-top: 2px;
    }

    .rz-grid-table thead th .rz-column-title{
        justify-content:center;
    }

    .rz-datatable-data td .rz-cell-data, .rz-grid-table td .rz-cell-data{
        text-align: center;
    }
</style>

<RadzenCard>
    <RadzenStack Orientation="Orientation.Vertical" Gap="1rem">
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
            <RadzenText Style="font-weight: 500; font-size: 1.25rem;">@_localizer["lbl_InterpolationTableConfig"]</RadzenText>
        </RadzenStack>

        @if (_isLoading)
        {
            <div class="text-center p-4">
                <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" Style="margin-bottom: 10px;" />
                <p>@_localizer["msg_LoadingSettings"]</p>
            </div>
        }
        else
        {
            <RadzenDataGrid @ref="_grid" Data="@_settings" TItem="FT06_InterpolationTable" Style="margin-top: 20px;max-height: calc(100vh - 260px);">
                <Columns>
                    <RadzenDataGridColumn TItem="FT06_InterpolationTable" Property="Z" Title="Z" Width="50px">
                        <Template Context="setting">
                            @setting.Z
                        </Template>
                    </RadzenDataGridColumn>
                    
                    @foreach (var column in _columns)
                    {
                        var currentColumn = column;
                        var colNumber = int.Parse(currentColumn.Replace("Col", ""));
                        var isEditable = colNumber % 10 == 0;
                        var groupNumber = (colNumber / 10) % 2;
                        <RadzenDataGridColumn TItem="FT06_InterpolationTable" Property="@column" Title="@colNumber.ToString().PadLeft(2,'0')" Width="120px">
                            <Template Context="setting">
                                <div class="interpolation-group-@(groupNumber) @(isEditable ? "edit-cell" : "")">
                                    @{
                                        var value = GetPropertyValue(setting, currentColumn);
                                        var displayValue = value == Math.Floor(value) ? value.ToString("N0") : value.ToString("N2");
                                    }
                                    <div style="display: flex; justify-content: center; align-items: center; height: 100%;">
                                        <RadzenTextBox Value="@displayValue" 
                                                    @onclick="() => OnCellClick(setting, currentColumn)"
                                                    Style="width: 100%; background: transparent; text-align: center;" 
                                                    ReadOnly="true"/>
                                    </div>
                                    @if (isEditable)
                                    {
                                        var nextCol = int.Parse(currentColumn.Replace("Col", "")) + 1;
                                        var nextColName = $"Col{nextCol:D2}";
                                        var nextValue = GetPropertyValue(setting, nextColName);
                                        var currentValue = GetPropertyValue(setting, currentColumn);
                                        var increment = nextValue - currentValue;

                                      <div class="increment-helper">
                                          @_localizer["lbl_Increment"]: @(increment == Math.Floor(increment) ? increment.ToString("N0") : increment.ToString("N2"))
                                      </div>
                                    }
                                </div>
                            </Template>
                        </RadzenDataGridColumn>
                    }
                </Columns>
            </RadzenDataGrid>
        }
    </RadzenStack>
</RadzenCard>

@code {
    private List<FT06_InterpolationTable> _settings = new();
    private List<string> _columns = new();
    private bool _isLoading = true;
    private bool _isSaving = false;
    private RadzenDataGrid<FT06_InterpolationTable> _grid;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await _ft06Service.GetAllAsync();
            _settings = result.Data;
            _columns = typeof(FT06_InterpolationTable).GetProperties()
                .Where(p => p.Name != "Z" && p.Name != "Id")
                .Select(p => p.Name)
                .ToList();
            _isLoading = false;
        }
        catch (Exception ex)
        {
            _notificationService.Notify(NotificationSeverity.Error, "Error", "Failed to load reservoir chart settings.");
            Console.Error.WriteLine(ex);
        }
    }

    private double GetPropertyValue(FT06_InterpolationTable setting, string propertyName)
    {
        var property = typeof(FT06_InterpolationTable).GetProperty(propertyName);
        return property?.GetValue(setting) as double? ?? 0;
    }

    private async Task OnCellClick(FT06_InterpolationTable setting, string propertyName)
    {
        try
        {
            // Only allow editing the first column in each 10-column group (Col00, Col10, Col20, etc.)
            if (int.TryParse(propertyName.Replace("Col", ""), out int colNumber) && colNumber % 10 == 0)
            {
                var currentValue = GetPropertyValue(setting, propertyName);
                double increment = 0;
    
                // Calculate initial increment based on next editable column's value
                if (colNumber < 90) // Make sure we don't go out of bounds
                {
                    var nextCol = $"Col{colNumber + 1:D2}";
                    var nextProperty = typeof(FT06_InterpolationTable).GetProperty(nextCol);
                    if (nextProperty != null)
                    {
                        var nextValue = nextProperty.GetValue(setting) as double? ?? 0;
                        increment = Math.Round(nextValue - currentValue, 2);
                    }
                }
    
                var result = await _dialogService.OpenAsync<InterpolationValueDialog>(
                    _localizer["lbl_InterpolationValue"],
                    new Dictionary<string, object>() { 
                        { "CurrentValue", currentValue },
                        { "Increment", increment }
                    },
                    new DialogOptions() { Width = "500px" });

    
                if (result != null)
                {
                    var values = (double[])result;
                    var baseValue = values[0];
                    var newIncrement = values[1];
                    
                    // Calculate values for the 10-column group
                    for (int i = 0; i < 10; i++)
                    {
                        var currentCol = $"Col{colNumber + i:D2}";
                        var property = typeof(FT06_InterpolationTable).GetProperty(currentCol);
                        if (property != null)
                        {
                            var calculatedValue = baseValue + (newIncrement * i);
                            property.SetValue(setting, calculatedValue);
                        }
                    }
                    
                    // Save changes
                    await _ft06Service.UpdateAsync(setting);
                    _notificationService.Notify(NotificationSeverity.Success, _localizer["lbl_Success"], _localizer["msg_UpdateSuccess"]);
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch (Exception ex)
        {
            _notificationService.Notify(NotificationSeverity.Error, _localizer["lbl_Error"], _localizer["msg_UpdateError"]);
            Console.Error.WriteLine(ex);
        }
    }
}