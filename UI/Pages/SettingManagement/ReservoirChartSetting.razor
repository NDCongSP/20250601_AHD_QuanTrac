@page "/reservoir-chart-setting"
@using Radzen
@using Radzen.Blazor
@using Microsoft.AspNetCore.Authorization
@using Microsoft.Extensions.Localization
@using Domain
@using Application.Services
@attribute [Authorize(Policy = "Admin")]

<RadzenCard>
    <RadzenStack Orientation="Orientation.Vertical" Gap="1rem">
        <RadzenText Style="font-weight: 500; font-size: 1.25rem;">Cấu hình bảng tra mực nước hồ chứa</RadzenText>

        @if (_isLoading)
        {
            <div class="text-center p-4">
                <p>Đang tải dữ liệu...</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <RadzenDataGrid TItem="FT05_ChartHoChua" 
                               Data="@_settings" 
                               Style="width:100%"
                               AllowPaging="true"
                               PageSize="30"
                               ShowPagingSummary="true" PageSizeOptions="@PageSizeOptions"
                               PagingSummaryFormat="@_localizer["PagingSummaryFormat"]" PageSizeText="@_localizer["items per page"]">
                    <Columns>
                        <RadzenDataGridColumn TItem="FT05_ChartHoChua" 
                                            Title="X_Value" 
                                            Property="X_Value" 
                                            Width="120px" />
                        
                        @foreach (var column in _columns)
                        {
                            <RadzenDataGridColumn TItem="FT05_ChartHoChua" 
                                                Title="@column"
                                                Width="120px">
                                <Template Context="setting">
                                    <RadzenNumeric TValue="double?"
                                                Value="@GetPropertyValue(setting, column)" 
                                                ValueChanged="@(value => OnCellValueChanged(setting, column, value))"
                                                Style="width: 100%" 
                                                @onkeydown:preventDefault />
                                </Template>
                            </RadzenDataGridColumn>
                        }
                    </Columns>
                </RadzenDataGrid>
            </div>
        }
    </RadzenStack>
</RadzenCard>

@code {
    private List<FT05_ChartHoChua> _settings = new();
    private List<string> _columns = new();
    private bool _isLoading = true;
    public static IEnumerable<int> PageSizeOptions = [30, 100, 200];
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await _ft05Service.GetAllAsync();
            _settings = result.Data;
            
            _columns = typeof(FT05_ChartHoChua).GetProperties()
                .Where(p => p.Name != "Index" && p.Name != "X_Value" && p.Name != "Id")
                .Select(p => p.Name)
                .ToList();
                
            _isLoading = false;
        }
        catch (Exception ex)
        {
            _notificationService.Notify(NotificationSeverity.Error, "Lỗi", "Không thể tải dữ liệu.");
            Console.Error.WriteLine(ex);
        }
    }
    
    private double? GetPropertyValue(FT05_ChartHoChua setting, string propertyName)
    {
        if (setting == null || string.IsNullOrEmpty(propertyName))
            return null;
            
        var property = typeof(FT05_ChartHoChua).GetProperty(propertyName);
        if (property == null)
            return null;
            
        try
        {
            var value = property.GetValue(setting);
            if (value == null)
                return null;
                
            if (value is double d)
                return d;
                
            if (double.TryParse(value.ToString(), out double result))
                return result;
                
            return null;
        }
        catch
        {
            return null;
        }
    }
    
    private async Task OnCellValueChanged(FT05_ChartHoChua setting, string propertyName, double? value)
    {
        try
        {
            var property = typeof(FT05_ChartHoChua).GetProperty(propertyName);
            if (property != null)
            {
                if (new[] { "L_MNC", "L_CTDD", "L_MNKT", "L_MNTK", "L_MNDBT" }.Contains(propertyName))
                {
                    foreach (var record in _settings)
                    {
                        property.SetValue(record, value);
                        await _ft05Service.UpdateAsync(record);
                    }
                }
                else
                {
                    property.SetValue(setting, value);
                    await _ft05Service.UpdateAsync(setting);
                }
                _notificationService.Notify(NotificationSeverity.Success, "Success", "Cập nhật dữ liệu thành công!");
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            _notificationService.Notify(NotificationSeverity.Error, "Lỗi", "Không thể cập nhật dữ liệu.");
            Console.Error.WriteLine(ex);
        }
    }
}