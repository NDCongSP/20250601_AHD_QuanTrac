@using Application.DTOs.Request.Account
@inject DialogService DialogService
@inject IStringLocalizer<CommonResources> _localizer

<RadzenTemplateForm TItem="ChangePassRequestDTO" Data="@Model" Submit="@OnSubmit">
    <RadzenRow Gap="1rem" Class="padding-body-content">
        <RadzenColumn SizeXS="12" SizeSM="4">
            <RadzenFormField Text="@_localizer["CurrentPassword"]" Variant="Variant.Outlined" Style="width:100%">
                <RadzenPassword Name="_txtCurrent" @bind-Value="@Model.CurrentPassword" />
            </RadzenFormField>
            <RadzenRequiredValidator Component="_txtCurrent" Popup="false" Style="position: absolute" />
        </RadzenColumn>
        <RadzenColumn SizeXS="12" SizeSM="4">
            <RadzenFormField Text="@_localizer["New Password"]" Variant="Variant.Outlined" Style="width:100%">
                <RadzenPassword Name="_txtNew" @bind-Value="@Model.NewPassword" />
            </RadzenFormField>
            <RadzenRequiredValidator Component="_txtNew" Popup="false" Style="position: absolute" />
        </RadzenColumn>
        <RadzenColumn SizeXS="12" SizeSM="4">
            <RadzenFormField Text="@_localizer["Confirm New Password"]" Variant="Variant.Outlined" Style="width:100%">
                <RadzenPassword Name="_txtConfirm" @bind-Value="@Model.ConfirmNewPassword" />
            </RadzenFormField>
            <RadzenRequiredValidator Component="_txtConfirm" Popup="false" Style="position: absolute" />
        </RadzenColumn>
    </RadzenRow>
    <RadzenRow Gap="1rem" Class="padding-body-content">
        <RadzenColumn SizeXS="12" SizeSM="12" class="d-flex justify-content-end mt-3">
            <RadzenStack Orientation="Radzen.Orientation.Horizontal" JustifyContent="Radzen.JustifyContent.Start" Gap="1rem">
                <RadzenButton ButtonType="Radzen.ButtonType.Submit" Icon="save" Text="@_localizer["Save"]" />
                <RadzenButton Click="@(() => DialogService.Close(null))" Icon="cancel" Text="@_localizer["btn_Cancel"]" />
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>
</RadzenTemplateForm>

@code {
    [Parameter] public ChangePassRequestDTO Model { get; set; }

    async Task OnSubmit()
    {
        if (string.IsNullOrWhiteSpace(Model.NewPassword) || Model.NewPassword != Model.ConfirmNewPassword)
        {
            return; // validators / parent will warn
        }
        DialogService.Close(Model);
    }
}


