@using Domain
@using Radzen.Blazor
@page "/spillway/gate-info"
@using System.Timers
@using UI.StaticClass
@attribute [Authorize(Policy = "Admin")]

<style>
    :root {
        --rz-primary-2: #1FB0A9;
        --rz-text-inverse: #fff;
    }
    .gate-header {
        background-color: var(--rz-primary-2);
        color: var(--rz-text-inverse) !important;
        text-align: center;
        padding: 8px;
        font-weight: bold;
        border-radius: 4px;
        margin-bottom: 1rem;
    }
    
    .btn-active, .btn-inactive, .btn-emergency {
        pointer-events: none !important;
        cursor: default !important;
        opacity: 1 !important;
    }
    .btn-active:hover, .btn-inactive:hover, .btn-emergency:hover {
        transform: none !important;
        box-shadow: none !important;
    }
    .btn-active:active, .btn-inactive:active, .btn-emergency:active {
        transform: none !important;
        box-shadow: none !important;
    }
    
    .param-row {
        display: flex;
        align-items: center;
        margin-bottom: 0.75rem;
        padding: 0.5rem;
        border-radius: 4px;
        background-color: var(--rz-base-background-color);
        border: 1px solid var(--rz-border-color);
    }
    
    .param-label-box {
        margin-right: 0.5rem;
        color: var(--rz-text-color);
    }
    
    .param-value {
        font-weight: 500;
        margin-right: 0.25rem;
        color: var(--rz-text-color);
    }
    
    /* Dark mode text colors */
    .rz-application[data-theme="dark"] .param-row,
    .rz-application[data-theme="dark"] .param-value,
    .rz-application[data-theme="dark"] .param-unit,
    .rz-application[data-theme="dark"] .rz-textbox-disabled {
        color: #ffffff !important;
    }
    
    /* Ensure disabled inputs have proper contrast in dark mode */
    .rz-application[data-theme="dark"] .rz-textbox-disabled {
        background-color: transparent !important;
        border-color: var(--rz-border-color) !important;
    }
    
    .param-unit {
        color: var(--rz-text-secondary-color);
        font-size: 0.9em;
    }
    
    .operation-panel {
        background: var(--rz-base-background-color) !important;
        padding: 10px;
        border-radius: 4px;
        border: 1px solid var(--rz-border-color);
    }
    
    .status-circle {
        display: inline-block;
        border-radius: 50%;
        margin-right: 8px;
        background-color: var(--rz-border-color);
    }

    .status-circle {
        display: inline-block;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        margin-right: 8px;
        border: 1px solid #ccc;
        background-color: #fff;
    }

    .status-circle-green {
        background-color: #00FF00; /* Green */
        border: 1px solid #FF0000;
        border: 1px solid #FF0000;
    }

    .status-circle-yellow {
        background-color: #FFFF00;
        border: 1px solid #FF0000;
        border-color: #FFFF00;
    }

    .status-circle-red {
        background-color: #FF0000;
        border: 1px solid #FF0000;
    }
    .ml-1 {
        margin-left: 0.25rem;
    }
    
    .mb-2 {
        margin-bottom: 0.5rem;
    }
    .btn-active{
        background-color: #ADFF29 !important;
        color: blue !important;
        width: 100%;
    }

    .btn-inactive{
        background-color: #F0F0F0 !important;
        color: blue !important;
        width: 100%;
    }

    .btn-emergency{
        background-color: !important;
        color: white !important;
        width: 100%;
    }
    /* Water level visual */
	.water-level-container {
		position: relative;
		width: 100%;
        height: 100%;
        background-color: #9CB5D6;
	}
	.water-level-fill {
		position: absolute;
		bottom: 0;
		width: 100%;
		transition: height 300ms ease;
        background-color: #4692D3;
	}

	/* Operation buttons */
	.rz-button.btn-active {
		background-color: #C6FF3D; /* lime highlight */
		border: 1px solid #9ad62b;
		color: #0f172a; /* slate-900 */
		font-weight: 600;
		box-shadow: inset 0 0 0 2px rgba(154, 214, 43, 0.15);
	}
	.rz-button.btn-active:hover { filter: brightness(0.98); }

	.rz-button.btn-inactive {
		background-color: #f8fafc; /* slate-50 */
		border: 1px solid #e2e8f0; /* slate-200 */
		font-weight: 600;
	}
	.rz-button.btn-inactive:hover { background-color: #f1f5f9; }

	.rz-button.btn-emergency {
		background-color: #fff5f5;
		border: 1px solid #fca5a5;
		color: #b91c1c;
		font-weight: 700;
	}
	.rz-button.btn-emergency:hover { background-color: #fee2e2; }

	/* Ensure full-width and spacing are consistent */
	.rz-button.btn-active,
	.rz-button.btn-inactive,
	.rz-button.btn-emergency {
		width: 100%;
		border-radius: 6px;
		padding: 0.65rem 0.75rem;
	}
</style>

<RadzenTabsItem Text="@($"CỬA {GateNo}")">
    <RadzenRow>
        <RadzenColumn SizeXS="12" SizeMD="12">
            <div class="gate-header">
                CỬA @(GateNo)
            </div>
        </RadzenColumn>
        <RadzenColumn SizeXS="12" SizeMD="3">
            <div class="param-row">
                <RadzenTextBox Value="Mực nước hồ (MN hồ):" Disabled="true" class="param-label-box" Style="width: 200px;" />
                <span class="param-value">@($"{Station.Fllow_Ho:F0}")</span>
                <span class="param-unit">m</span>
            </div>
            <div class="param-row">
                <RadzenTextBox Value="Nhiệt độ dầu:" Disabled="true" class="param-label-box" Style="width: 200px;" />
                <span class="param-value">@($"{Station.S1_Temp_Oil ?? 0:F1}")</span>
                <span class="param-unit">°C</span>
            </div>
            <div class="param-row">
                <RadzenTextBox Value="Hành trình xy lanh 1_1:" Disabled="true" class="param-label-box" Style="width: 200px;" />
                <span class="param-value">@($"{Station.HT_Cylinder1_1 ?? 0:F0}")</span>
                <span class="param-unit">mm</span>
            </div>
            <div class="param-row">
                <RadzenTextBox Value="Hành trình xy lanh 1_2:" Disabled="true" class="param-label-box" Style="width: 200px;" />
                <span class="param-value">@($"{Station.HT_Cylinder1_2 ?? 0:F0}")</span>
                <span class="param-unit">mm</span>
            </div>
        </RadzenColumn>
        <RadzenColumn SizeXS="12" SizeMD="3">
            @{var WaterLevelHeight = Math.Round((double)Station.Fllow_Door1 / 510 * 100, 0);}
            <div class="water-level-container">
                <div class="water-level-fill" style="height: @WaterLevelHeight%;"></div>
            </div>
        </RadzenColumn>
        <RadzenColumn SizeXS="12" SizeMD="3">
            <div class="param-row">
                <RadzenTextBox Value="Độ mở cửa (a):" Disabled="true" class="param-label-box" Style="width: 200px;" />
                <span class="param-value">@($"{Station.Door1_Aperture ?? 0}")</span>
                <span class="param-unit">cm</span>
            </div>
            <div class="param-row">
                <RadzenTextBox Value="Lưu lượng cửa 1 (Qi):" Disabled="true" class="param-label-box" Style="width: 200px;" />
                <span class="param-value">@($"{Station.Fllow_Door1 ?? 0:F1}")</span>
                <span class="param-unit">m³/s</span>
            </div>
            <div class="param-row">
                <RadzenTextBox Value="Lưu lượng tổng (Qtr):" Disabled="true" class="param-label-box" Style="width: 200px;" />
                <span class="param-value">@($"{GateData.CalculatorValue.Q_tr:F1}")</span>
                <span class="param-unit">m³/s</span>
            </div>
        </RadzenColumn>
        <RadzenColumn SizeXS="12" SizeMD="3">
            <RadzenFieldset Text="Vận Hành">
                <RadzenRow GutterSize="1rem">
                    <RadzenColumn Size="6">
                        <RadzenButton Text="Thủ công" Class="@(Station.Man.GetValueOrDefault() ? "btn-active" : "btn-inactive")" Style="width: 100%;" />
                    </RadzenColumn>
                    <RadzenColumn Size="6">
                        <RadzenButton Text="Tự động" Class="@(Station.Auto.GetValueOrDefault() ? "btn-active" : "btn-inactive")" Style="width: 100%;" />
                    </RadzenColumn>
                    <RadzenColumn Size="6">
                        <RadzenButton Text="Tại chỗ" Class="@(Station.Local.GetValueOrDefault() ? "btn-active" : "btn-inactive")" Style="width: 100%;" />
                    </RadzenColumn>
                    <RadzenColumn Size="6">
                        <RadzenButton Text="Từ xa" Class="@(Station.Remote.GetValueOrDefault() ? "btn-active" : "btn-inactive")" Style="width: 100%;" />
                    </RadzenColumn>
                    <RadzenColumn Size="12">
                        <RadzenButton Text="Dừng khẩn" Class="@(Station.Local_Stop.GetValueOrDefault() ? "btn-emergency" : "btn-inactive")" Style="width: 100%;" />
                    </RadzenColumn>
                </RadzenRow>
            </RadzenFieldset>
        </RadzenColumn>
        <RadzenColumn SizeXS="12" SizeMD="12" class="mt-3">
            <div class="gate-header">
                THÔNG TIN VẬN HÀNH CỬA @(GateNo)
            </div>
        </RadzenColumn>
        <RadzenColumn SizeXS="12" SizeMD="8" Class="operation-panel">
            <RadzenRow>
                <RadzenColumn SizeXS="12" SizeMD="12">
                    <RadzenRow>
                        <RadzenColumn SizeXS="12" SizeMD="6">
                            <RadzenFieldset Text="Bơm dầu">
                                <RadzenRow>
                                    <RadzenColumn Size="6">
                                        <div class="d-flex align-items-center mb-2"><span class="status-circle @(Station.DC1_Running == true ? "status-circle-green" : "")"></span> <span class="ml-1">Bơm 1</span></div>
                                        <div class="d-flex align-items-center mb-2"><span class="status-circle @(Station.DC2_Running == true ? "status-circle-green" : "")"></span> <span class="ml-1">Bơm 2</span></div>
                                        <div class="d-flex align-items-center"><span class="status-circle @(Station.DC3_Running == true ? "status-circle-green" : "")"></span> <span class="ml-1">Bơm chốt</span></div>
                                    </RadzenColumn>
                                    <RadzenColumn Size="6">
                                        <div class="d-flex align-items-center mb-2"><span class="status-circle @(Station.DC1_Over == true ? "status-circle-yellow" : "")"></span> <span class="ml-1">Lỗi bơm 1</span></div>
                                        <div class="d-flex align-items-center mb-2"><span class="status-circle @(Station.DC2_Over == true ? "status-circle-yellow" : "")"></span> <span class="ml-1">Lỗi bơm 2</span></div>
                                        <div class="d-flex align-items-center"><span class="status-circle @(Station.DC3_Over == true ? "status-circle-yellow" : "")"></span> <span class="ml-1">Lỗi bơm chốt</span></div>
                                    </RadzenColumn>
                                </RadzenRow>
                            </RadzenFieldset>
                        </RadzenColumn>
                        <RadzenColumn SizeXS="12" SizeMD="6">
                            <RadzenFieldset Text="Trạng thái cửa">
                                <div class="d-flex align-items-center mb-2"><span class="status-circle @(Station.Door1_Opening == true ? "status-circle-green" : "")"></span> <span class="ml-1">Cửa 1 đang mở</span></div>
                                <div class="d-flex align-items-center mb-2"><span class="status-circle @(Station.Door1_Closing == true ? "status-circle-red" : "")"></span> <span class="ml-1">Cửa 1 đang đóng</span></div>
                                <div class="d-flex align-items-center mb-2"><span class="status-circle @(Station.Door1_Open == true ? "status-circle-green" : "")"></span> <span class="ml-1">Cửa 1 mở hoàn toàn</span></div>
                                <div class="d-flex align-items-center"><span class="status-circle @(Station.Door1_Close == true ? "status-circle-red" : "")"></span> <span class="ml-1">Cửa 1 đóng hoàn toàn</span></div>
                            </RadzenFieldset>
                        </RadzenColumn>
                    </RadzenRow>
                </RadzenColumn>

                <RadzenColumn SizeXS="12" SizeMD="12">
                    <RadzenRow>
                        <RadzenColumn SizeXS="12" SizeMD="6">
                            <RadzenFieldset Text="Áp dầu">
                                <RadzenRow>
                                    <RadzenColumn Size="12">
                                        <div class="d-flex align-items-center mb-2"><span class="status-circle @(Station.Door1_PressureHigh == true ? "status-circle-red" : "")"></span> <span class="ml-1">Áp dầu cửa 1 cao</span></div>
                                        <div class="d-flex align-items-center"><span class="status-circle @(Station.Door1_PressureLow == true ? "status-circle-yellow" : "")"></span> <span class="ml-1">Áp dầu cửa 1 thấp</span></div>
                                    </RadzenColumn>
                                </RadzenRow>
                            </RadzenFieldset>
                        </RadzenColumn>
                        <RadzenColumn SizeXS="12" SizeMD="6">
                            <RadzenFieldset Text="Cửa">
                                <div class="d-flex align-items-center"><span class="status-circle @(Station.Al_Door1 == true ? "status-circle-red" : "")"></span> <span class="ml-1">Lỗi lệch cửa 1</span></div>
                            </RadzenFieldset>
                        </RadzenColumn>
                    </RadzenRow>
                </RadzenColumn>
            </RadzenRow>
        </RadzenColumn>
        <RadzenColumn SizeXS="12" SizeMD="4">
            <RadzenImage Path="images/generals/tranc.jpg" AlternateText="Sơ đồ cửa van" Style="width: 100%; height: auto;" />
        </RadzenColumn>
    </RadzenRow>
</RadzenTabsItem>
