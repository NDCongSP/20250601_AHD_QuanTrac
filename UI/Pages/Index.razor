@page "/"
@using Radzen

<!-- Mô phỏng cửa cống + thông số trái/phải -->
<div style="display: flex; justify-content: center; align-items: flex-start; margin: 20px 0;">
    <!-- Cột trái: HL -->
    <div style="margin-right: 20px;">
        @foreach (var item in dataHL)
        {
            <div
                style="width: 150px; background-color: #d8f0ff; border: 1px solid #ccc; padding: 10px; margin-bottom: 10px; text-align: center;">
                <strong>@item.Label</strong><br />
                @item.Value
            </div>
        }
    </div>

    <!-- Cửa cống mô phỏng -->
    <div style="width: 300px; height: 250px; border: 5px solid gray; position: relative;">
        <div style="position: absolute; bottom: 0; width: 100%; height: 80%; background-color: lightblue;"></div>
        <div style="position: absolute; bottom: 0; width: 100%; height: 10px; background-color: darkblue;"></div>
    </div>

    <!-- Cột phải: TL -->
    <div style="margin-left: 20px;">
        @foreach (var item in dataTL)
        {
            <div
                style="width: 150px; background-color: #d8f0ff; border: 1px solid #ccc; padding: 10px; margin-bottom: 10px; text-align: center;">
                <strong>@item.Label</strong><br />
                @item.Value
            </div>
        }
    </div>
</div>

<p style="text-align:center;">Độ mở cống: <strong>10.94 m (97.68%)</strong></p>

<div style="display: flex; justify-content: center; gap: 20px; margin-top: 30px;">
    <!-- Cột 1: Trạng thái thiết bị cửa cống -->
    <div style="background: #eaf3fb; border: 1px solid #b5c9e3; border-radius: 4px; width: 340px; padding: 0 0 16px 0;">
        <div
            style="background: #b5c9e3; color: #23406e; font-weight: bold; padding: 8px 16px; border-radius: 4px 4px 0 0; font-size: 16px;">
            TRẠNG THÁI THIẾT BỊ CỬA CỐNG
        </div>
        <div style="padding: 16px;">
            <div style="margin-bottom: 10px;">
                <span style="font-weight: 500;">Trạng thái cửa cống</span>
                <div>
                    @foreach (var option in trangThaiCuaOptions)
                    {
                        <label style="margin-right: 18px;">
                            <input type="radio" name="trangThaiCua" value="@option"
                                @onchange="(e => selectedTrangThaiCua = option)"
                                checked="@(selectedTrangThaiCua == option)" />
                            @option
                        </label>
                    }
                </div>
            </div>
            <div style="margin-bottom: 10px;">
                <span style="font-weight: 500;">Chế độ điều khiển</span>
                <div>
                    @foreach (var option in cheDoOptions)
                    {
                        <label style="margin-right: 18px;">
                            <input type="radio" name="cheDoDieuKhien" value="@option"
                                @onchange="(e => cheDoDieuKhien = option)" checked="@(cheDoDieuKhien == option)" />
                            @option
                        </label>
                    }
                </div>
            </div>
            <div>
                <span style="font-weight: 500;">Cơ chế điều khiển</span>
                <div>
                    @foreach (var option in coCheOptions)
                    {
                        <label style="margin-right: 18px;">
                            <input type="radio" name="coCheDieuKhien" value="@option"
                                @onchange="(e => coCheDieuKhien = option)" checked="@(coCheDieuKhien == option)" />
                            @option
                        </label>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Cột 2: Chế độ điều khiển bơm dầu -->
    <div style="background: #eaf3fb; border: 1px solid #b5c9e3; border-radius: 4px; width: 340px; padding: 0 0 16px 0;">
        <div
            style="background: #b5c9e3; color: #23406e; font-weight: bold; padding: 8px 16px; border-radius: 4px 4px 0 0; font-size: 16px;">
            CHẾ ĐỘ ĐIỀU KHIỂN BƠM DẦU
        </div>
        <div style="padding: 16px;">
            <div style="margin-bottom: 10px;">
                <span style="font-weight: 500;">Bơm dầu</span>
                <div>
                    @foreach (var option in bomDauOptions)
                    {
                        <label style="margin-right: 18px;">
                            <input type="radio" name="bomDau" value="@option" @onchange="(e => bomDau = option)"
                                checked="@(bomDau == option)" />
                            @option
                        </label>
                    }
                </div>
            </div>
            <div>
                <span style="font-weight: 500;">Chế độ điều khiển</span>
                <div>
                    <label style="margin-right: 18px;">
                        <input type="radio" name="cheDoBomDau" checked disabled />
                        Tại chỗ
                    </label>
                    <label>
                        <input type="radio" name="cheDoBomDau" disabled />
                        Từ xa
                    </label>
                </div>
            </div>
        </div>
    </div>

</div>


@code {
    string selectedTrangThaiCua = "Cửa đang mở";
    string cheDoDieuKhien = "Tại chỗ";
    string coCheDieuKhien = "Bán tự động";
    string bomDau = "Bơm ổn định";

    List<string> trangThaiCuaOptions = new() {
    "Cửa đang mở", "Cửa mở hết", "Cửa đang đóng", "Cửa đóng hết"
    };

    List<string> cheDoOptions = new() {
    "Tại chỗ", "Từ xa tại nhà quản lý", "Từ xa trên phần mềm"
    };

    List<string> coCheOptions = new() {
    "Tự động", "Bán tự động"
    };

    List<string> bomDauOptions = new() {
    "Bơm đầu ổn định", "Bơm đầu dinh"
    };
    class DisplayData
    {
        public string Label { get; set; }
        public string Value { get; set; }
    }

    List<DisplayData> dataHL = new()
    {
    new() { Label = "Mực nước HL", Value = "-3.64 m (07:53)" },
    new() { Label = "Độ mặn HL", Value = "0 % (07:53)" },
    new() { Label = "Áp suất trạm trụ phải", Value = "0 bar (07:53)" }
    };

    List<DisplayData> dataTL = new()
    {
    new() { Label = "Mực nước TL", Value = "-3.30 m (07:53)" },
    new() { Label = "Độ mặn TL", Value = "0 % (07:53)" },
    new() { Label = "Áp suất trạm trụ trái", Value = "0 bar (07:53)" }
    };

}
