@page "/dashboard"
@using System.Timers
<RadzenPanel class="rz-p-4 rz-border-radius-2 rz-mx-auto">
    <figure>
        <RadzenStack Orientation="Orientation.Vertical" JustifyContent="JustifyContent.Center">
            <RadzenRow>
                <RadzenColumn SizeXS="12" SizeMD="12" class="rz-mx-auto">
                    @((MarkupString)_svg)
                </RadzenColumn>
            </RadzenRow>
        </RadzenStack>
    </figure>
</RadzenPanel>

<style>

    figure {
        display: block;
        background: #fff;
        width: 100%;
        box-sizing: border-box;
        border: solid thin navy;
    }



        figure:nth-of-type(2n) {
            background: #bfc;
        }



        figcaption, figure > div {
            display: block;
            vertical-align: middle;
        }



        figure > div {
            text-align: center;
            width: 100%;
            height: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
        }



    img, svg, .bg-svg {
        border: thin dotted darkgrey;
        width: 100%;
        height: 100%;
        object-fit: contain;
    }



        svg.defs-only {
            display: block;
            position: absolute;
            height: 0;
            width: 0;
            margin: 0;
            padding: 0;
            border: none;
            overflow: hidden;
        }

</style>

@code {
    string _svg;
    private System.Timers.Timer _timer;

    protected override void OnInitialized()
    {
        using var stream = this.GetType().Assembly.GetManifestResourceStream("UI.wwwroot.images.generals.Home.svg");
        stream.Seek(0, SeekOrigin.Begin);
        StreamReader reader = new StreamReader(stream);
        _svg = reader.ReadToEnd();
        base.OnInitialized();

        #region Timer refresh data
        _timer = new System.Timers.Timer(GlobalVariable.ConfigSystem.RefreshInterval);
        _timer.Elapsed += RefreshData;
        _timer.Enabled = true;
        #endregion
    }

    private async void RefreshData(object? sender, ElapsedEventArgs e)
    {
        //try
        {
            var realtimeData = await _ft02Service.GetFirstOrDefaultRealTimeDisplay();

            StateHasChanged(); // NOTE: MUST CALL StateHasChanged() BECAUSE THIS IS TRIGGERED BY A TIMER INSTEAD OF A USER EVENT
        }
        //catch { }
    }

    public void Dispose()
    {
        _timer.Dispose();
    }
}
