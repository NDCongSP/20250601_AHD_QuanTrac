@page "/"
@using System.Timers
@using UI.StaticClass
<style>
    body {
        font-family: 'Times New Roman' !important;
    }
</style>
<RadzenPanel class="rz-p-4 rz-border-radius-2 rz-mx-auto">

    <figure>
        <RadzenStack Orientation="Orientation.Vertical" JustifyContent="JustifyContent.Center">
            <RadzenRow>
                <RadzenColumn SizeXS="12" SizeMD="12" class="rz-mx-auto">
                    @((MarkupString)_svg)
                </RadzenColumn>
            </RadzenRow>
        </RadzenStack>
    </figure>
</RadzenPanel>
@code {
    string _svg;
    private System.Timers.Timer _timer;
    private DotNetObjectReference<UI.Pages.Dashboard.Index> _selfRef;
    private RealtimeDisplayModel realtimeData = new();
    protected override void OnInitialized()
    {
        LayoutState.SetTitle(_localizer["QuanLyTran"]);
        using var stream = this.GetType().Assembly.GetManifestResourceStream("UI.wwwroot.images.generals.Home.svg");
        stream.Seek(0, SeekOrigin.Begin);
        StreamReader reader = new StreamReader(stream);
        _svg = reader.ReadToEnd();
        base.OnInitialized();
        RefreshData(null, null);

        #region Timer refresh data
        _timer = new System.Timers.Timer(GlobalVariable.ConfigSystem.TimerInterval);
        _timer.Elapsed += RefreshData;
        _timer.Enabled = true;
        #endregion
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
            await _jsRuntime.InvokeVoidAsync("dashboardSetRef", _selfRef);
        }
    }

    private async void RefreshData(object? sender, ElapsedEventArgs? e)
    {
        try
        {
            var data = await _ft02Service.GetFirstOrDefaultRealTimeDisplay();
            if (data.Stations.Any() && realtimeData.Stations.Any())
            {
                foreach (var item in data.Stations)
                {
                    if (item.StationId < 4)
                    {
                        if (item.Door1_Open == false && item.Door1_Opening == false && item.Door1_Closing == false && item.Door1_Close == false)
                        {
                            item.Door1_Open = true;
                        }

                        if (item.Door2_Open == false && item.Door2_Opening == false && item.Door2_Closing == false && item.Door2_Close == false)
                        {
                            item.Door2_Open = true;
                        }
                    }
                }
            }
            realtimeData = data;
            await _jsRuntime.InvokeVoidWithOriginalCaseAsync("updateSvgFillOverflow", realtimeData);
            StateHasChanged();
        }
        catch { }
    }

    [JSInvokable]
    public async Task OnSvgClicked(string value)
    {
        await OpenFT03ReportAsync(value, 10);
    }

    public void Dispose()
    {
        _timer.Dispose();
        _selfRef?.Dispose();
    }

    public async Task OpenFT03ReportAsync(string paramName, int frequency = 10)
    {
        await _dialogService.OpenAsync<UI.Pages.Dashboard.FT03ReportDialog>(
        $"Báo cáo {GetDisplayName(paramName)}",
        new Dictionary<string, object>()
        {
{ nameof(FT03ReportDialog.ParamName), paramName },
{ nameof(FT03ReportDialog.Frequency), frequency }
        },
        new DialogOptions() { Width = "1200px", Height = "700px" }
        );
    }

    private static string GetDisplayName(string paramName)
    {
        return paramName switch
        {
            "API_Fllow_BinhNham" => "TRẠM BÌNH NHÂM",
            "API_Fllow_BenSuc" => "TRẠM BẾN SÚC",
            "API_Fllow_DauTieng" => "TRẠM TV DẦU TIẾNG",
            "API_Fllow_SonDai" => "TRẠM SƠN ĐÀI",
            "Fllow_Ho" => "MN HỒ (TL-TXL)",
            "API_Fllow_TL_CDD" => "MN HỒ (TL-CDD)",
            _ => paramName
        };
    }
}
