@inherits LayoutComponentBase
@implements IDisposable
@using Radzen
@using Radzen.Blazor
@using Radzen.Blazor.Rendering
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components
@inject UI.Services.LayoutStateService LayoutState
@inject UI.Services.ThemeService ThemeService
@inject ILogger<MainLayout> Logger
@inject NavigationManager _navigation
@inject IJSRuntime _jsRuntime
@inject AuthenticationStateProvider _authStateProvider
@inject HttpClient _httpClient

<RadzenLayout Class="rz-layout">
    <RadzenHeader Class="rz-header">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
            JustifyContent="JustifyContent.SpaceBetween" Gap="0" Class="rz-py-2 rz-px-4">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
                <button class="mobile-menu-btn" @onclick="ToggleSidebar">
                    <i class="rz-icon-menu"></i>
                </button>
                <RadzenSidebarToggle Click="@(() => { sidebarExpanded = !sidebarExpanded; StateHasChanged(); })" />
                @* when click redirect to '/' *@
                <RadzenImage src="images/generals/logo-removebg-preview.png" Style="cursor: pointer;background:#fff; width: 70px;border-radius: 50%;" Click="@(() => _navigation.NavigateTo("/"))"/>
                <RadzenStack Gap="0">
                    @if (!string.IsNullOrEmpty(LayoutState.Subtitle))
                    {
                        <RadzenText Text="@LayoutState.Subtitle" TextStyle="TextStyle.Subtitle2" Class="rz-mb-0"
                            Style="color: white; opacity: 0.8;" />
                    }
                    <RadzenText Text="@LayoutState.Title" TextStyle="TextStyle.H6" Class="rz-mb-0"
                        Style="color: white;" />
                </RadzenStack>
            </RadzenStack>
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                @*     <div class="language-switcher" style="display: flex; align-items: center; margin-right: 0.5rem;">
                <select @onchange="HandleLanguageChange" style="padding: 0.25rem; border-radius: 4px; border: 1px solid #ccc;">
                <option value="vi">VI</option>
                <option value="en">EN</option>
                </select>
                </div> *@
                <RadzenProfileMenu Style="background-color:transparent" Click="OnLanguageMenuClick">
                    <Template>
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                            <img src="@(currentCulture == "vi-VN" ? "images/flags/vi.png" : "images/flags/en.png")"
                                style="width: 40px; height: 30px;" />
                        </RadzenStack>
                    </Template>
                    <ChildContent>
                        <RadzenProfileMenuItem Text="@_localizer["Vietnamese"]" Value="vi-VN">
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                                Gap="0.5rem">
                                <img src="images/flags/vi.png" style="width: 40px; height: 30px;" />
                                <span>@_localizer["Vietnamese"]</span>
                            </RadzenStack>
                        </RadzenProfileMenuItem>
                        <RadzenProfileMenuItem Text="@_localizer["English"]" Value="en-US">
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                                Gap="0.5rem">
                                <img src="images/flags/en.png" style="width: 40px; height: 30px;" />
                                <span>@_localizer["English"]</span>
                            </RadzenStack>
                        </RadzenProfileMenuItem>
                    </ChildContent>
                </RadzenProfileMenu>
                <RadzenButton Icon="notifications" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text" />
                @if (GlobalVariable.UserAuthorizationInfo != null)
                {
                    <RadzenProfileMenu Style="background-color:transparent" Click="OnParentClicked">
                        <Template>
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                                <RadzenIcon Icon="account_circle" />
                                @if (sidebarExpanded)
                                {
                                    <span>@GlobalVariable.UserAuthorizationInfo.FullName</span>
                                }
                            </RadzenStack>
                        </Template>
                        <ChildContent>
                            <RadzenProfileMenuItem Text="Profile" Icon="person" Path="/profile" />
                            <RadzenProfileMenuItem Text="Settings" Icon="settings" Path="/settings" />
                            <RadzenProfileMenuItem Text="Change Password" Icon="password" Path="/change-password" />
                            <RadzenProfileMenuItem Text="Logout" Icon="logout" />
                        </ChildContent>
                    </RadzenProfileMenu>
                }
                else
                {
                    <RadzenButton Icon="account_circle" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text" Title="Login"
                        Click="@(() => _navigation.NavigateTo("/login"))" />
                }
                <RadzenButton Icon="settings" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text" />
                <RadzenAppearanceToggle />
            </RadzenStack>
        </RadzenStack>
    </RadzenHeader>
    <div class="rz-sidebar-overlay @(sidebarExpanded ? "show" : "")" @onclick="() => { sidebarExpanded = false; StateHasChanged(); }"></div>
    <RadzenSidebar @ref="sidebar" Responsive="false" Class="@(sidebarExpanded ? "rz-sidebar-show" : "")" Style="@(sidebarExpanded ? "width: 280px" : "width: 70px")">
        <RadzenPanelMenu DisplayStyle="@(sidebarExpanded? MenuItemDisplayStyle.IconAndText: MenuItemDisplayStyle.Icon)"
            ShowArrow="false">
            <RadzenPanelMenuItem Path="/dashboard" Text="@_localizer["HomePage"]" Icon="dashboard" />
            <RadzenPanelMenuItem Path="/reservoir" Text="@_localizer["Reservoir"]" Icon="water_drop" />
            <RadzenPanelMenuItem Path="/spillway" Text="@_localizer["SpillwayDischarge"]" Icon="analytics" />
            <RadzenPanelMenuItem Path="/water-level" Text="@_localizer["WaterLevelHLSSG"]" Icon="water" />
            <RadzenPanelMenuItem Path="/alert" Text="@_localizer["Alerts"]" Icon="notification_important" />
            <RadzenPanelMenuItem Path="/report" Text="@_localizer["Reports"]" Icon="receipt" />


            <RadzenPanelMenuItem Text="@_localizer["MasterData"]" Icon="build">
                <RadzenPanelMenuItem Path="/location-management" Text="@_localizer["StationDeclaration"]" Icon="location_city" />
                <RadzenPanelMenuItem Path="/setting-management" Text="@_localizer["CoefficientManagement"]" Icon="equalizer" />
                <RadzenPanelMenuItem Path="/reservoir-chart-setting" Text="@_localizer["ReservoirChartSetting"]" Icon="equalizer" />
                <RadzenPanelMenuItem Path="/water-level-data-configuration" Text="@_localizer["WaterLevelDataConfiguration"]" Icon="equalizer" />
                <RadzenPanelMenuItem Path="/interpolation-table-data-configuration" Text="@_localizer["InterpolationTableDataConfiguration"]" Icon="equalizer" />
                <!--add 1 line border phân tách 2 phần-->
                <hr />
                <RadzenPanelMenuItem Path="/users" Text="@_localizer["UserManagement"]" Icon="person" />
                <RadzenPanelMenuItem Path="/roles" Text="@_localizer["Roles"]" Icon="lock_open" />
                <RadzenPanelMenuItem Path="/permissions" Text="@_localizer["Permissions"]" Icon="gavel" />
                <hr />
                <RadzenPanelMenuItem Path="/scada-users" Text="@_localizer["ScadaUsers"]" Icon="person" />
            </RadzenPanelMenuItem>
        </RadzenPanelMenu>
    </RadzenSidebar>
    <RadzenBody>
        <div class="" style="background-color: var(--rz-grid-header-background-color);">
            @Body
        </div>
    </RadzenBody>
    <RadzenFooter Style="text-align: right;">
        @_localizer["Copyright"] © 2025 AHD - PT. All rights reserved.
    </RadzenFooter>
</RadzenLayout>

@code {
    private bool sidebarExpanded = false; // Hidden by default on mobile
    private string currentCulture = "vi";
    private RadzenSidebar? sidebar;
    private bool isMobile = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            isMobile = await _jsRuntime.InvokeAsync<bool>("eval", "window.innerWidth < 993");
            // Always start with sidebar hidden on mobile
            if (isMobile)
            {
                sidebarExpanded = false;
                StateHasChanged();
            }
            
            // Add window resize event listener
            await _jsRuntime.InvokeVoidAsync("eval", @"
                window.addEventListener('resize', function() {
                    const isMobileNow = window.innerWidth < 993;
                    if (isMobileNow) {
                        // Close sidebar when resizing to mobile view
                        document.querySelector('.rz-sidebar').classList.remove('rz-sidebar-show');
                        document.querySelector('.rz-sidebar-overlay').classList.remove('show');
                    }
                    DotNet.invokeMethodAsync('UI', 'OnWindowResize', window.innerWidth);
                });
            ");
        }
    }

    [JSInvokable]
    public static void OnWindowResize(int width)
    {
        // This method will be called from JavaScript when the window is resized
    }

    private async Task ToggleSidebar()
    {
        sidebarExpanded = !sidebarExpanded;
        
        if (isMobile && _jsRuntime != null)
        {
            try 
            {
                // Toggle body scroll lock when sidebar is open/closed on mobile
                await _jsRuntime.InvokeVoidAsync("eval", @"
                    document.body.style.overflow = arguments[0] ? 'hidden' : '';
                ", sidebarExpanded);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error toggling sidebar scroll lock");
            }
        }
        
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        await ThemeService.InitializeAsync();
        LayoutState.OnChange += StateHasChanged;
        ThemeService.OnChange += StateHasChanged;
        LayoutState.SetTitle("CÔNG TY TNHH MTV KHAI THÁC THỦY LỢI MIỀN NAM");

        // Get current culture from localStorage
        var culture = await _jsRuntime.InvokeAsync<string>("localStorage.getItem", "culture");
        if (!string.IsNullOrEmpty(culture))
        {
            currentCulture = culture;
            await _jsRuntime.InvokeVoidAsync("setCulture", currentCulture);
        }
    }

    private async Task OnLanguageMenuClick(RadzenProfileMenuItem item)
    {
        if (item != null && !string.IsNullOrEmpty(item.Value))
        {
            currentCulture = item.Value;
            // Save to localStorage
            await _jsRuntime.InvokeVoidAsync("localStorage.setItem", "culture", currentCulture);

            // Apply the culture
            await _jsRuntime.InvokeVoidAsync("setCulture", currentCulture);

            // Reload the page to apply culture changes
            _navigation.NavigateTo(_navigation.Uri, forceLoad: true);
        }
    }

    public void Dispose()
    {
        LayoutState.OnChange -= StateHasChanged;
        ThemeService.OnChange -= StateHasChanged;
    }

    async Task ToggleTheme()
    {
        await ThemeService.ToggleThemeAsync();
    }

    async Task OnParentClicked(RadzenProfileMenuItem args)
    {
        if (args.Text == "Logout")
        {
            GlobalVariable.AuthenticationStateTask = null;
            GlobalVariable.UserAuthorizationInfo = null;
            GlobalVariable.UserAuthorizationInfo = new UserAuthorizationInfo();
            
            if (_authStateProvider is ApiAuthenticationStateProvider authProvider)
            {
                authProvider.MarkUserAsLoggedOut();
            }
            
            // Clear the authorization header
            _httpClient.DefaultRequestHeaders.Authorization = null;
            
            _navigation.NavigateTo("/login");
        }
    }

    async void ChangePassword()
    {
