@page "/rolelist"
@inherits ViewManagerBase
@using Application.DTOs.Response.Account

<ViewManager TItem="GetRoleResponseDTO"
             OnReturnToList="HandleReturnToList"
             NeedsRefresh="_needsRefresh"
             NeedsRefreshChanged="HandleNeedsRefreshChanged">
    <ListView Context="listContext">
        <Roles OnAddNew="listContext.OnAddNew"
                     OnEdit="listContext.OnEdit"
                     OnView="listContext.OnView"
                     NeedsRefresh="_needsRefresh" />
    </ListView>
    <DetailView Context="detailContext">
        <DialogCardPageAddNewRole Title="@detailContext.Title"
                                  Id="@_selectedUnitId"
                                  OnSaved="detailContext.OnSaved"
                                  OnCancelled="detailContext.OnCancelled" />
    </DetailView>
</ViewManager>
