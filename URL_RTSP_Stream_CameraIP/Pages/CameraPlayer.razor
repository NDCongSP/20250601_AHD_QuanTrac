    private string hlsStreamUrl10 = "http://14.224.229.6:8888/Cam10/index.m3u8";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Gọi hàm JavaScript để tải video
            await JSRuntime.InvokeVoidAsync("loadHlsPlayer", "my-camera-video1", hlsStreamUrl1);
            await JSRuntime.InvokeVoidAsync("loadHlsPlayer", "my-camera-video2", hlsStreamUrl2);
            await JSRuntime.InvokeVoidAsync("loadHlsPlayer", "my-camera-video3", hlsStreamUrl3);
            await JSRuntime.InvokeVoidAsync("loadHlsPlayer", "my-camera-video4", hlsStreamUrl4);
            await JSRuntime.InvokeVoidAsync("loadHlsPlayer", "my-camera-video5", hlsStreamUrl5);
            await JSRuntime.InvokeVoidAsync("loadHlsPlayer", "my-camera-video6", hlsStreamUrl6);
            await JSRuntime.InvokeVoidAsync("loadHlsPlayer", "my-camera-video7", hlsStreamUrl7);
            await JSRuntime.InvokeVoidAsync("loadHlsPlayer", "my-camera-video8", hlsStreamUrl8);
            // await JSRuntime.InvokeVoidAsync("loadHlsPlayer", "my-camera-video9", hlsStreamUrl9);
            // await JSRuntime.InvokeVoidAsync("loadHlsPlayer", "my-camera-video10", hlsStreamUrl10);
        }
